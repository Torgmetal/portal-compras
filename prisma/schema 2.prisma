// Schema do Portal de Compras Torg Metal
// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USUÁRIOS / AUTENTICAÇÃO ────────────────────────────────

enum Role {
  ADMIN
  COMERCIAL
  ENGENHARIA
  ALMOXARIFADO
  COMPRAS
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // bcrypt hash
  role      Role
  setor     String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opsCriadas    OP[]       @relation("OPCreatedBy")
  rmsCriadas    RM[]       @relation("RMCreatedBy")
  aditivos      Aditivo[]
  auditLogs     AuditLog[]
}

// ─── OP (ORDEM DE PRODUÇÃO) ─────────────────────────────────

enum OPStatus {
  ABERTA
  EM_EXECUCAO
  ENCERRADA
  CANCELADA
}

model OP {
  id          String   @id @default(cuid())
  numero      String   @unique // T083, T084, etc
  cliente     String
  obra        String?
  descricao   String?
  status      OPStatus @default(ABERTA)

  createdById String
  createdBy   User     @relation("OPCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itens       OPItem[]
  aditivos    Aditivo[]
  rms         RM[]

  @@index([numero])
  @@index([status])
}

model OPItem {
  id              String  @id @default(cuid())
  opId            String
  op              OP      @relation(fields: [opId], references: [id], onDelete: Cascade)

  ordem           Int     @default(0)
  descricao       String
  codigoOmie      String?
  unidade         String  // KG, UN, M, etc
  qtdContratada   Float
  valorVerba      Float   // R$ alocado pra esse item
  faturamentoDireto Boolean @default(false)
  observacao      String?

  rmItens         RMItem[]

  @@index([opId])
}

// Aditivos: registram a razão da mudança em uma OP
// O aditivo edita os itens diretamente; aqui guardamos o porquê + autor + data
model Aditivo {
  id          String   @id @default(cuid())
  opId        String
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)
  numero      Int      // 1, 2, 3...
  descricao   String   // razão / breve descrição

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([opId, numero])
  @@index([opId])
}

// ─── RM (REQUISIÇÃO DE MATERIAL) ────────────────────────────

enum RMStatus {
  ABERTA
  EM_COTACAO
  COTADA
  PEDIDO_GERADO
  CANCELADA
}

model RM {
  id          String   @id @default(cuid())
  numero      String   @unique // RM-0001
  opId        String
  op          OP       @relation(fields: [opId], references: [id])
  tipo        String   @default("Material") // Material, Consumível
  descricao   String
  observacao  String?
  status      RMStatus @default(ABERTA)

  // Configuração para pedido Omie (escolhida na RM)
  categoriaCompra String?
  localEstoque    String?

  // Solicitante
  createdById String
  createdBy   User     @relation("RMCreatedBy", fields: [createdById], references: [id])
  setor       String?  // setor capturado no momento da criação (snapshot)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itens       RMItem[]
  cotacoes    Cotacao[]
  envios      Envio[]
  anexos      Anexo[]

  @@index([opId])
  @@index([status])
  @@index([createdById])
}

model RMItem {
  id          String  @id @default(cuid())
  rmId        String
  rm          RM      @relation(fields: [rmId], references: [id], onDelete: Cascade)

  // Vinculo com item da OP (sempre que a RM nasce de uma OP)
  opItemId    String?
  opItem      OPItem? @relation(fields: [opItemId], references: [id])

  ordem       Int     @default(0)
  descricao   String
  unidade     String
  qtd         Float
  // Detalhe (do Tekla quando importado)
  material    String?
  comprimento String?
  largura     String?
  peso        Float?
  pesoLinear  Float?
  codigo      String?
  tratamento  String?

  cotacaoItens CotacaoItem[]

  @@index([rmId])
  @@index([opItemId])
}

// ─── COTAÇÕES ───────────────────────────────────────────────

enum CotacaoStatus {
  PENDENTE      // aguardando fornecedor responder
  RECEBIDA      // fornecedor respondeu
  VENCIDA       // passou do prazo
  CANCELADA
}

model Cotacao {
  id              String        @id @default(cuid())
  rmId            String
  rm              RM            @relation(fields: [rmId], references: [id], onDelete: Cascade)

  // Fornecedor (pode estar cadastrado localmente ou só vir do Omie)
  fornecedorNome  String
  fornecedorEmail String?
  nCodOmie        String?       // codigo do fornecedor no Omie
  cnpj            String?

  faturamento     String        @default("Torg") // Torg | Cliente
  prazoPagamento  String?
  observacao      String?
  total           Float         @default(0)

  prazoResposta   DateTime?     // limite pra fornecedor responder
  recebidaEm      DateTime?
  status          CotacaoStatus @default(PENDENTE)

  // Token único para acesso do fornecedor (uploads via /fornecedores/c/[token])
  token           String?       @unique

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  itens           CotacaoItem[]
  anexos          Anexo[]

  @@index([rmId])
  @@index([status])
  @@index([token])
}

model CotacaoItem {
  id          String  @id @default(cuid())
  cotacaoId   String
  cotacao     Cotacao @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rmItemId    String
  rmItem      RMItem  @relation(fields: [rmItemId], references: [id])

  precoUnit   Float
  qtdCotada   Float
  qtdProposta Float?
  icmsPct     Float?
  ipiPct      Float?
  observacao  String?
  vencedor    Boolean @default(false) // marcado quando o compras escolhe

  @@index([cotacaoId])
  @@index([rmItemId])
}

// Histórico de e-mails enviados aos fornecedores
model Envio {
  id              String   @id @default(cuid())
  rmId            String
  rm              RM       @relation(fields: [rmId], references: [id], onDelete: Cascade)
  fornecedorNome  String
  fornecedorEmail String
  data            DateTime @default(now())
  status          String   @default("Enviado")

  @@index([rmId])
}

// ─── ANEXOS (Vercel Blob) ───────────────────────────────────

model Anexo {
  id          String   @id @default(cuid())

  // Polimórfico — pode estar vinculado a RM ou Cotacao
  cotacaoId   String?
  cotacao     Cotacao? @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rmId        String?
  rm          RM?      @relation(fields: [rmId], references: [id], onDelete: Cascade)

  nomeArquivo String
  blobUrl     String   // URL do Vercel Blob
  tamanho     Int      // bytes
  tipo        String   // pdf, image/png, etc
  uploadedAt  DateTime @default(now())

  @@index([cotacaoId])
  @@index([rmId])
}

// ─── AUDITORIA ──────────────────────────────────────────────

// Log de todas as ações pra rastreabilidade
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // create_op, update_op_item, delete_rm, etc
  entity    String   // OP, RM, Cotacao, OPItem, etc
  entityId  String
  diff      Json?    // {before, after} se aplicável
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
