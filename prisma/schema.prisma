generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String                @id @default(cuid())
  email                    String                @unique
  name                     String
  password                 String
  setor                    String?
  ativo                    Boolean               @default(true)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  podeAlterarVerba         Boolean               @default(false)
  tipo                     TipoUsuario
  aditivos                 Aditivo[]
  ajustesPrazoCriados      AjustePrazo[]         @relation("AjustePrazoCreatedBy")
  auditLogs                AuditLog[]
  consultasEstoqueCriadas  ConsultaEstoque[]     @relation("ConsultaEstoqueCreatedBy")
  consultaItensRespondidos ConsultaEstoqueItem[] @relation("ConsultaItemRespondidoPor")
  cronogramaRegistros      CronogramaRegistro[]  @relation("CronogramaRegistroCreatedBy")
  cronogramaRevisoes       CronogramaRevisao[]   @relation("CronogramaRevisaoCreatedBy")
  cronogramaCobrancas      CronogramaCobranca[]  @relation("CobrancaCreatedBy")
  necessidadesSemanais     NecessidadeSemanal[]  @relation("NecessidadeSemanalCreatedBy")
  notificacoes             Notificacao[]
  opsCriadas               OP[]                  @relation("OPCreatedBy")
  orcamentosCriados        Orcamento[]           @relation("OrcamentoCriadoPor")
  passwordResetTokens      PasswordResetToken[]
  prazoHistoricos          PrazoHistorico[]
  producaoDiarias          ProducaoDiaria[]      @relation("ProducaoDiariaCreatedBy")
  estudosCriados           PropostaEstudo[]      @relation("EstudoCriadoPor")
  rmsCriadas               RM[]                  @relation("RMCreatedBy")
  recebimentos             Recebimento[]
  pedidosRecebidos         PedidoOmie[]          @relation("PedidoRecebidoPor")
  revisoesCriadas          Revisao[]             @relation("RevisaoCreatedBy")
  sharepointSyncs          SharepointSync[]
  solicitacoesCriadas      SolicitacaoVerba[]    @relation("SolicitacaoCreatedBy")
  solicitacoesDecididas    SolicitacaoVerba[]    @relation("SolicitacaoDecididoBy")
  tarefasPlanejamento      TarefaPlanejamento[]  @relation("TarefaPlanejamentoCreatedBy")
  modulos                  UserModulo[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Meta {
  id          String   @id @default(cuid())
  modulo      String
  tipo        String
  setor       String   @default("GERAL")
  ano         Int
  mes         Int
  valorMensal Float    @default(0)
  semana1     Float?
  semana2     Float?
  semana3     Float?
  semana4     Float?
  semana5     Float?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([modulo, tipo, setor, ano, mes])
  @@index([modulo, ano])
  @@index([modulo, tipo, ano])
}

model UserModulo {
  id     String @id @default(cuid())
  userId String
  modulo Modulo
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modulo])
  @@index([userId])
}

model OP {
  id                   String               @id @default(cuid())
  numero               String               @unique
  cliente              String
  obra                 String?
  descricao            String?
  status               OPStatus             @default(ABERTA)
  createdById          String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  dataFimPrevista      DateTime?
  dataFimReal          DateTime?
  dataInicio           DateTime?
  clienteCep           String?
  clienteCidade        String?
  clienteCnpj          String?
  clienteContato       String?
  clienteEmail         String?
  clienteEndereco      String?
  clienteIE            String?
  clienteRazaoSocial   String?
  clienteTelefone      String?
  clienteUF            String?
  valorTotalContrato   Float?
  aditivos             Aditivo[]
  ajustesPrazo         AjustePrazo[]
  cronogramas          Cronograma[]
  estoqueAlocacoes     EstoqueAlocacao[]
  estoqueReservas      EstoqueReserva[]
  fluxoCaixa           FluxoCaixa[]
  mesApontamentos      MesApontamento[]     @relation("MesApontamentosOP")
  necessidadesSemanais NecessidadeSemanal[]
  createdBy            User                 @relation("OPCreatedBy", fields: [createdById], references: [id])
  itens                OPItem[]
  medicoes             OPMedicao[]
  receitas             OPReceita[]
  orcamentos           Orcamento[]          @relation("OrcamentoOP")
  pecasConjunto        PecaConjunto[]
  pedidosOmieAvulsos   PedidoOmie[]
  planejamentosCarga   PlanejamentoCarga[]
  producaoSemanal      ProducaoSemanal[]
  rms                  RM[]
  rmItensDestino       RMItem[]             @relation("RMItemOpDestino")
  revisoes             Revisao[]
  romaneios            Romaneio[]
  tarefasPlanejamento  TarefaPlanejamento[]

  @@index([numero])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdById, status])
}

model ProducaoSemanal {
  id              String   @id @default(cuid())
  semana          String
  dataInicio      DateTime
  dataFim         DateTime
  pesoPrevistoKg  Float    @default(0)
  pesoRealizadoKg Float    @default(0)
  valorPrevisto   Float    @default(0)
  valorRealizado  Float    @default(0)
  opId            String?
  observacao      String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  data            DateTime
  fonte           String?
  setor           String?
  op              OP?      @relation(fields: [opId], references: [id])

  @@unique([data, opId, setor])
  @@index([data])
  @@index([semana])
  @@index([opId])
  @@index([setor])
}

model Romaneio {
  id                String             @id @default(cuid())
  numero            String
  opId              String?
  data              DateTime
  pesoRealKg        Float
  descricao         String?
  observacao        String?
  valorPorKg        Float?
  valorTotal        Float?
  createdById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  planejamentoCarga PlanejamentoCarga?
  op                OP?                @relation(fields: [opId], references: [id])
  itens             RomaneioItem[]

  @@index([opId])
  @@index([data])
}

model RomaneioItem {
  id             String        @id @default(cuid())
  romaneioId     String
  tipo           String
  descricao      String
  pecaConjuntoId String?
  rmItemId       String?
  qtd            Float         @default(1)
  pesoKg         Float?
  observacao     String?
  createdAt      DateTime      @default(now())
  pecaConjunto   PecaConjunto? @relation(fields: [pecaConjuntoId], references: [id])
  rmItem         RMItem?       @relation(fields: [rmItemId], references: [id])
  romaneio       Romaneio      @relation(fields: [romaneioId], references: [id], onDelete: Cascade)

  @@index([romaneioId])
  @@index([pecaConjuntoId])
  @@index([rmItemId])
}

model PlanejamentoCarga {
  id           String                  @id @default(cuid())
  opId         String
  dataPrevista DateTime
  descricao    String?
  status       String                  @default("PLANEJADO")
  romaneioId   String?                 @unique
  createdById  String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  op           OP                      @relation(fields: [opId], references: [id])
  romaneio     Romaneio?               @relation(fields: [romaneioId], references: [id])
  itens        PlanejamentoCargaItem[]

  @@index([opId])
  @@index([status])
  @@index([dataPrevista])
}

model PlanejamentoCargaItem {
  id                 String            @id @default(cuid())
  planejamentoId     String
  tipo               String
  descricao          String
  pecaConjuntoId     String?
  rmItemId           String?
  qtdPlanejada       Float             @default(1)
  qtdCarregada       Float             @default(0)
  pesoEstimadoKg     Float?
  status             String            @default("PLANEJADO")
  motivoNaoEnvio     String?
  reprogramadoParaId String?
  createdAt          DateTime          @default(now())
  pecaConjunto       PecaConjunto?     @relation(fields: [pecaConjuntoId], references: [id])
  planejamento       PlanejamentoCarga @relation(fields: [planejamentoId], references: [id], onDelete: Cascade)
  rmItem             RMItem?           @relation(fields: [rmItemId], references: [id])

  @@index([planejamentoId])
  @@index([pecaConjuntoId])
  @@index([rmItemId])
  @@index([status])
}

model FluxoCaixa {
  id            String    @id @default(cuid())
  data          DateTime
  tipo          String
  categoria     String
  descricao     String
  valor         Float
  realizado     Boolean   @default(false)
  dataRealizado DateTime?
  opId          String?
  observacao    String?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  op            OP?       @relation(fields: [opId], references: [id])

  @@index([data])
  @@index([tipo])
  @@index([categoria])
  @@index([opId])
}

model OPMedicao {
  id                String    @id @default(cuid())
  opId              String
  numeroPedidoOmie  String
  codigoPedidoOmie  String?
  descricao         String?
  data              DateTime?
  valorBruto        Float     @default(0)
  valorLiquido      Float?
  status            String?
  etapa             String?
  qtdItens          Int       @default(0)
  ultimoSync        DateTime?
  syncErro          String?
  payload           Json?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tipoDocumento     String    @default("VENDA")
  valorContratado   Float?
  valorFaturadoAuto Float?
  op                OP        @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, numeroPedidoOmie])
  @@index([opId])
}

model OPReceita {
  id            String   @id @default(cuid())
  opId          String
  ordem         Int      @default(0)
  categoria     String
  descricao     String
  cfop          String?
  codigoServico String?
  valor         Float
  icmsPct       Float?
  ipiPct        Float?
  pisPct        Float?
  cofinsPct     Float?
  issPct        Float?
  irrfPct       Float?
  csllPct       Float?
  observacao    String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  op            OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@index([opId])
  @@index([categoria])
}

model OPItem {
  id                String             @id @default(cuid())
  opId              String
  ordem             Int                @default(0)
  descricao         String
  codigoOmie        String?
  unidade           String?
  qtdContratada     Float?
  valorVerba        Float
  faturamentoDireto Boolean            @default(false)
  observacao        String?
  capacidade        String?
  categoria         String
  meses             Int?
  tipo              ItemTipo           @default(VERBA)
  valorPorMes       Float?
  cmcMedio          Float?
  localEstoque      String?
  op                OP                 @relation(fields: [opId], references: [id], onDelete: Cascade)
  rmItens           RMItem[]
  solicitacoesVerba SolicitacaoVerba[]

  @@index([opId])
  @@index([categoria])
}

model Revisao {
  id          String   @id @default(cuid())
  opId        String
  numero      Int
  motivo      String
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("RevisaoCreatedBy", fields: [createdById], references: [id])
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, numero])
  @@index([opId])
}

model Aditivo {
  id          String        @id @default(cuid())
  opId        String
  numero      Int
  descricao   String
  createdById String
  createdAt   DateTime      @default(now())
  createdBy   User          @relation(fields: [createdById], references: [id])
  op          OP            @relation(fields: [opId], references: [id], onDelete: Cascade)
  itens       AditivoItem[]

  @@unique([opId, numero])
  @@index([opId])
}

model AditivoItem {
  id                String             @id @default(cuid())
  aditivoId         String
  ordem             Int                @default(0)
  descricao         String
  codigoOmie        String?
  unidade           String?
  qtdContratada     Float?
  valorVerba        Float
  faturamentoDireto Boolean            @default(false)
  observacao        String?
  capacidade        String?
  categoria         String
  meses             Int?
  tipo              ItemTipo           @default(VERBA)
  valorPorMes       Float?
  cmcMedio          Float?
  localEstoque      String?
  aditivo           Aditivo            @relation(fields: [aditivoId], references: [id], onDelete: Cascade)
  rmItens           RMItem[]
  solicitacoesVerba SolicitacaoVerba[]

  @@index([aditivoId])
  @@index([categoria])
}

model AjustePrazo {
  id              String   @id @default(cuid())
  opId            String
  dataFimAnterior DateTime
  dataFimNova     DateTime
  motivo          String
  createdById     String
  createdAt       DateTime @default(now())
  createdBy       User     @relation("AjustePrazoCreatedBy", fields: [createdById], references: [id])
  op              OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@index([opId])
}

model SolicitacaoVerba {
  id               String                 @id @default(cuid())
  opItemId         String?
  aditivoItemId    String?
  valorAtual       Float
  valorProposto    Float
  justificativa    String
  status           SolicitacaoVerbaStatus @default(PENDENTE)
  observacaoMaster String?
  decididoEm       DateTime?
  decididoById     String?
  createdById      String
  createdAt        DateTime               @default(now())
  aditivoItem      AditivoItem?           @relation(fields: [aditivoItemId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("SolicitacaoCreatedBy", fields: [createdById], references: [id])
  decididoBy       User?                  @relation("SolicitacaoDecididoBy", fields: [decididoById], references: [id])
  opItem           OPItem?                @relation(fields: [opItemId], references: [id], onDelete: Cascade)

  @@index([opItemId])
  @@index([aditivoItemId])
  @@index([status])
}

model RM {
  id                 String            @id @default(cuid())
  numero             String            @unique
  opId               String?
  tipo               String            @default("Material")
  descricao          String
  observacao         String?
  status             RMStatus          @default(ABERTA)
  categoriaCompra    String?
  localEstoque       String?
  createdById        String
  setor              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  categoriasOP       String[]          @default([])
  tipoRM             TipoRM            @default(ENGENHARIA)
  anexos             Anexo[]
  consultasEstoque   ConsultaEstoque[]
  cotacoes           Cotacao[]
  envios             Envio[]
  pedidosFDAtendidos PedidoOmie[]      @relation("PedidoOmieRMAtendida")
  createdBy          User              @relation("RMCreatedBy", fields: [createdById], references: [id])
  op                 OP?               @relation(fields: [opId], references: [id])
  itens              RMItem[]

  @@index([opId])
  @@index([status])
  @@index([createdById])
  @@index([status, createdAt])
  @@index([opId, status])
}

model PedidoOmie {
  id                   String           @id @default(cuid())
  cotacaoId            String?
  fornecedorNome       String
  nCodFor              String?
  cnpj                 String?
  codigoPedido         String?
  numeroPedido         String?
  total                Float            @default(0)
  faturamentoDireto    Boolean          @default(false)
  status               String           @default("CRIADO")
  observacao           String?
  erroOmie             String?
  payload              Json?
  resposta             Json?
  createdById          String?
  createdAt            DateTime         @default(now())
  anexoNome            String?
  anexoUrl             String?
  criadoManualmente    Boolean          @default(false)
  opId                 String?
  categoriaItem        String?
  itensDetalhes        Json?
  rmAtendidaId         String?
  dataEntregaReal      DateTime?
  prazoEntregaPrevisto DateTime?
  statusEntrega        String?
  prazoOriginal        DateTime?
  tokenEntrega         String?          @unique
  itensOmie            Json?
  nfNumero             String?
  nfSerie              String?
  nfChave              String?
  recebidoPorId        String?
  recebidoEm           DateTime?
  recebidoPor          User?            @relation("PedidoRecebidoPor", fields: [recebidoPorId], references: [id])
  cotacao              Cotacao?         @relation(fields: [cotacaoId], references: [id])
  op                   OP?              @relation(fields: [opId], references: [id])
  rmAtendida           RM?              @relation("PedidoOmieRMAtendida", fields: [rmAtendidaId], references: [id])
  prazoHistorico       PrazoHistorico[]
  rmItens              RMItem[]
  recebimentos         Recebimento[]

  @@index([cotacaoId])
  @@index([opId])
  @@index([status])
}

model PrazoHistorico {
  id            String     @id @default(cuid())
  pedidoId      String
  prazoAnterior DateTime?
  prazoNovo     DateTime
  motivo        String?
  alteradoPorId String?
  criadoEm      DateTime   @default(now())
  alteradoPor   User?      @relation(fields: [alteradoPorId], references: [id])
  pedido        PedidoOmie @relation(fields: [pedidoId], references: [id])

  @@index([pedidoId])
}

model RMItem {
  id                     String                  @id @default(cuid())
  rmId                   String
  opItemId               String?
  ordem                  Int                     @default(0)
  descricao              String
  unidade                String
  qtd                    Float
  material               String?
  comprimento            String?
  largura                String?
  peso                   Float?
  pesoLinear             Float?
  codigo                 String?
  tratamento             String?
  aditivoItemId          String?
  canceladoEm            DateTime?
  canceladoMotivo        String?
  atendidoEstoqueEm      DateTime?
  atendidoEstoqueQtd     Float?
  atendidoEstoqueObs     String?
  atendidoEstoquePreco   Float?
  atendidoEstoqueTotal   Float?
  status                 RMItemStatus            @default(PENDENTE)
  pedidoOmieId           String?
  codigoOmieEstoque      String?
  destinoEstoque         Boolean                 @default(false)
  opDestinoId            String?
  consultaEstoqueItens   ConsultaEstoqueItem[]
  cotacaoItens           CotacaoItem[]
  planejamentoCargaItens PlanejamentoCargaItem[]
  aditivoItem            AditivoItem?            @relation(fields: [aditivoItemId], references: [id])
  opDestino              OP?                     @relation("RMItemOpDestino", fields: [opDestinoId], references: [id])
  opItem                 OPItem?                 @relation(fields: [opItemId], references: [id])
  pedidoOmie             PedidoOmie?             @relation(fields: [pedidoOmieId], references: [id])
  rm                     RM                      @relation(fields: [rmId], references: [id], onDelete: Cascade)
  recebimentos           Recebimento[]
  romaneioItens          RomaneioItem[]

  @@index([rmId])
  @@index([opItemId])
  @@index([aditivoItemId])
  @@index([status])
  @@index([pedidoOmieId])
  @@index([status, opDestinoId])
  @@index([rmId, status])
}

model Cotacao {
  id                     String        @id @default(cuid())
  rmId                   String
  fornecedorNome         String
  fornecedorEmail        String?
  nCodOmie               String?
  cnpj                   String?
  faturamento            String        @default("Torg")
  prazoPagamento         String?
  observacao             String?
  total                  Float         @default(0)
  prazoResposta          DateTime?
  recebidaEm             DateTime?
  status                 CotacaoStatus @default(PENDENTE)
  token                  String?       @unique
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  numeroRevisao          Int           @default(0)
  totalProposta          Float?
  solicitadaRevisaoFinal DateTime?
  fornecedorId           String?
  numeroProposta         String?
  anexos                 Anexo[]
  fornecedor             Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  rm                     RM            @relation(fields: [rmId], references: [id], onDelete: Cascade)
  itens                  CotacaoItem[]
  pedidosOmie            PedidoOmie[]

  @@index([rmId])
  @@index([fornecedorId])
  @@index([status])
  @@index([token])
  @@index([status, createdAt])
  @@index([rmId, status])
}

model CotacaoItem {
  id           String    @id @default(cuid())
  cotacaoId    String
  rmItemId     String
  precoUnit    Float
  qtdCotada    Float
  qtdProposta  Float?
  icmsPct      Float?
  ipiPct       Float?
  observacao   String?
  vencedor     Boolean   @default(false)
  prazoEntrega DateTime?
  semEstoque   Boolean   @default(false)
  cotacao      Cotacao   @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rmItem       RMItem    @relation(fields: [rmItemId], references: [id])

  @@index([cotacaoId])
  @@index([rmItemId])
  @@index([cotacaoId, vencedor])
  @@index([rmItemId, vencedor])
}

model Envio {
  id              String   @id @default(cuid())
  rmId            String
  fornecedorNome  String
  fornecedorEmail String
  data            DateTime @default(now())
  status          String   @default("Enviado")
  rm              RM       @relation(fields: [rmId], references: [id], onDelete: Cascade)

  @@index([rmId])
}

model Anexo {
  id          String   @id @default(cuid())
  cotacaoId   String?
  rmId        String?
  nomeArquivo String
  blobUrl     String
  tamanho     Int
  tipo        String
  uploadedAt  DateTime @default(now())
  cotacao     Cotacao? @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rm          RM?      @relation(fields: [rmId], references: [id], onDelete: Cascade)

  @@index([cotacaoId])
  @@index([rmId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Fornecedor {
  id               String    @id @default(cuid())
  razaoSocial      String
  nomeFantasia     String?
  cnpj             String?
  email            String
  emailsAdicionais String[]
  telefone         String?
  contato          String?
  cidade           String?
  uf               String?
  categorias       String[]
  observacao       String?
  nCodOmie         String?
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cotacoes         Cotacao[]

  @@index([ativo])
}

model EmailNotificacao {
  id        String   @id @default(cuid())
  email     String
  nome      String?
  eventos   String[]
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
}

model CategoriaFornecedor {
  id        String   @id @default(cuid())
  codigo    String   @unique
  label     String
  color     String   @default("slate")
  ordem     Int      @default(100)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notificacao {
  id           String          @id @default(cuid())
  tipo         NotificacaoTipo
  titulo       String
