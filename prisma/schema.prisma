// Solicitação de início de produção criada pelo Planejamento a partir das datas
// do cronograma (necessidade do cliente) — uma por obra. As datas necessárias
// por setor ficam em `datasSetor` (JSON { CORTE: "YYYY-MM-DD", ... }). Vai para
// PCP/Produção (notificação) e aparece no PMP para acompanhamento.
model SolicitacaoProducao {
  id             String    @id @default(cuid())
  opNumero       String    @unique
  opId           String?
  cronogramaId   String?
  dataEntrega    DateTime? @db.Date
  datasSetor     Json      @default("{}")
  hhPorTonManual Float? // produtividade informada no Planejamento (sobrepõe o comercial)
