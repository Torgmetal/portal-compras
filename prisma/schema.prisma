// ── PMP — Plano Mestre de Producao ────────────────────────────
// Meta diaria de producao por OP + setor.
// Visao semanal = SUM(metas da semana).
model PmpMeta {
  id          String   @id @default(cuid())
  data        DateTime @db.Date // dia-alvo
  setor       String // CORTE, MONTAGEM, SOLDA, ACABAMENTO, JATO, PINTURA, EXPEDIDO
  opNumero    String // OP
  metaPecas   Int      @default(0) // meta em pecas
  metaPesoKg  Float    @default(0) // meta em kg
  observacao  String?
  criadoPorId String
  criadoPor   User     @relation("PmpMetaCriador", fields: [criadoPorId], references: [id])
  // opNumero é string livre (sem FK): obras do Syneco/LPC (ex.: T60B) podem
  // não estar cadastradas como OP no portal e mesmo assim ter meta no PMP.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([data, setor, opNumero])
  @@index([data])
  @@index([opNumero])
}

model Compromisso {
  id          String              @id @default(cuid())
  titulo      String
  descricao   String?
  data        DateTime
  concluido   Boolean             @default(false)
  concluidoEm DateTime?
  userId      String
  tarefaId    String?
  opNumero    String?
  setor       String?
  prioridade  String              @default("MEDIA")
  criadoPorId String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation("CompromissoUser", fields: [userId], references: [id])
  tarefa      TarefaPlanejamento? @relation(fields: [tarefaId], references: [id])
  criadoPor   User?               @relation("CompromissoCriadoPor", fields: [criadoPorId], references: [id])

  @@index([userId, data])
  @@index([userId, concluido])
  @@index([tarefaId])
}

// Obras ocultadas do Relatório de Produção POR SETOR (ex.: OPs já finalizadas
// num setor). Só some da VISÃO do relatório — nenhum dado é apagado. ADMIN-only.
model RelatorioCorteObraOculta {
  id           String   @id @default(cuid())
  obra         String
  setor        String   @default("CORTE")
  ocultadoPor  String?
  ocultadoNome String?
  criadoEm     DateTime @default(now())

  @@unique([obra, setor])
}

// Baixa manual no Relatório de Produção: OP já finalizada cujo apontamento no
// Syneco ficou incompleto. Marca a obra/setor como 100% concluída SÓ na visão
// do relatório (não altera o Syneco nem o mesOrdem; sobrevive ao sync). ADMIN-only.
model RelatorioObraConcluida {
  id            String   @id @default(cuid())
  obra          String
  setor         String   @default("CORTE")
  concluidoPor  String?
  concluidoNome String?
  criadoEm      DateTime @default(now())

  @@unique([obra, setor])
}

// Baixa da carteira do Dashboard do PCP: obra/frente (opNumero da PecaConjunto)
// já finalizada, removida da "Necessidade por obra". Só esconde da VISÃO do
// dashboard — não altera o status das peças. Reversível, ADMIN-only.
model PcpCarteiraObraBaixa {
  id          String   @id @default(cuid())
  opNumero    String   @unique
  baixadoPor  String?
  baixadoNome String?
  criadoEm    DateTime @default(now())
}

// Heartbeat dos crons — cada cron registra sua última execução (ok/erro/duração).
// O cron "monitor" lê isto e alerta (e-mail) se algum cron não roda há tempo
// demais ou falhou. Guarda-corpo contra cron morrer silenciosamente.
model CronHeartbeat {
  job       String    @id // ex.: "sync-entregas", "estoque-produtos"
  lastRunAt DateTime  @default(now())
  lastOkAt  DateTime?
  ok        Boolean   @default(true)
  mensagem  String?
  duracaoMs Int?
  updatedAt DateTime  @updatedAt
}
