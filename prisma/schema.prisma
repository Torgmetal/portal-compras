model PecaConjunto {
  id                     String                  @id @default(cuid())
  opId                   String?
  opNumero               String
  item                   Int?
  marca                  String
  descricao              String?
  qte                    Int                     @default(1)
  pesoUnitKg             Float                   @default(0)
  pesoTotalKg            Float                   @default(0)
  status                 String                  @default("PENDENTE")
  fluxoEspecial          Boolean                 @default(false)
  ultimoSetor            String?
  dataConcluida          DateTime?
  dataPrevista           DateTime?
  fonte                  String?
  observacao             String?
  criadoEm               DateTime                @default(now())
  atualizadoEm           DateTime                @updatedAt
  precoTotal             Float                   @default(0)
  precoUnitario          Float                   @default(0)
  // Campos LPC — conjunto/croqui
  tipoPeca               String?                 // "CONJUNTO" | "CROQUI" | null (legado LE)
  material               String?                 // "A36", "A572-GR.50"
  perfil                 String?                 // "W410X46.1", "CH4.80X70"
  comprimentoMm          Float?                  // comprimento em mm
  areaPinturaM2          Float?                  // area de pintura m²
  statusPrep             String?                 // "PENDENTE" | "PREPARADO" (so croquis)
  maquina                String?                 // maquina de corte atribuida (LASER_CHAPA, LASER_PERFIL, LASER_TUBO, LASER_CANTONEIRA)
  // Campos de produção (populados pelo Syneco)
  qteProduzida           Int                     @default(0)
  pesoProduzido          Float                   @default(0)
  dataProducao           DateTime?               // data fim da produção (Syneco)
  op                     OP?                     @relation(fields: [opId], references: [id])
  planejamentos          PecaPlanejamento[]
  planejamentoCargaItens PlanejamentoCargaItem[]
  romaneioItens          RomaneioItem[]
  // Relacoes conjunto<->croqui (many-to-many via junction)
  conjuntoCroquis        ConjuntoCroqui[]        @relation("ConjuntoCroquis_conjunto")
  croquiConjuntos        ConjuntoCroqui[]        @relation("ConjuntoCroquis_croqui")

  @@unique([opNumero, marca])
  @@index([opId])
  @@index([status])
  @@index([marca])
  @@index([tipoPeca])
}

// Relacao many-to-many: qual croqui pertence a qual conjunto
