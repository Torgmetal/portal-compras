  planejadoUn   Float     @default(0)
  produzidoUn   Float     @default(0)
  rejeitadoUn   Float     @default(0)
  saldoUn       Float     @default(0)
  pesoPlanejado Float     @default(0)
  pesoProduzido Float     @default(0)
  saldoRestante Float     @default(0)
  status        String?
  productionId  Int?
  dataInicio    DateTime?
  dataFim       DateTime?
  opId          String?
  syncRunId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([obra, op, operacao, item])
  @@index([obra])
  @@index([setor])
  @@index([status])
  @@index([opId])
}

// Setores "inativos sem produção" no Syneco (IsEnabled=0 e PartCount=0) — etapas
// feitas FORA da fábrica/terceirizadas. Usado SÓ no relatório de furos de
// apontamento, para não acusar falso furo (ex.: Pintura X acima de Montagem 0
// quando Montagem foi feita fora). Sincronizado do banco do Syneco (tabela
// Production) e SUBSTITUÍDO por inteiro a cada sync (self-correcting: se o
// gerente reativar um setor no SSP, ele sai desta lista no próximo sync).
model MesInativo {
  id           String   @id @default(cuid())
  op           String
  item         String
  operacao     String
  atualizadoEm DateTime @default(now())

  @@unique([op, item, operacao])
  @@index([item])
}

model MesSyncLog {
  id          String   @id @default(cuid())
  sucesso     Boolean
  dataInicio  DateTime
  dataFim     DateTime
  totalLinhas Int      @default(0)
  criados     Int      @default(0)
  atualizados Int      @default(0)
  ignorados   Int      @default(0)
  erro        String?
  duracaoMs   Int      @default(0)
  criadoEm    DateTime @default(now())

  @@index([criadoEm])
  @@index([sucesso])
}

// Allowlist do módulo Diretoria (acesso restrito). O dono (vitor@torg.com.br) é
// sempre liberado em código; esta tabela guarda quem ele liberou além dele.
// Nem ADMIN entra sem estar aqui (gate próprio em lib/diretoria.js).
model AcessoDiretoria {
  id               String   @id @default(cuid())
  email            String   @unique
  nome             String?
  liberadoPorEmail String?
  createdAt        DateTime @default(now())
}

// Override manual da data prevista de faturamento por OP (módulo Diretoria).
// Quando existe, prevalece sobre a data automática (cronograma › prazo da OP).
model DiretoriaFaturamentoData {
  id              String   @id @default(cuid())
  opId            String   @unique
  dataFaturamento DateTime
  observacao      String?
  atualizadoPor   String?
  createdAt       DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}

// Config chave-valor do módulo Diretoria (ex: id "saldoCaixa" = saldo de caixa
// atual, usado como ponto de partida do fluxo de caixa diário).
model DiretoriaConfig {
  id            String   @id
  valor         Float    @default(0)
  observacao    String?
  atualizadoPor String?
  atualizadoEm  DateTime @updatedAt
}

// Conferência/rastreabilidade de lançamentos financeiros (módulo Diretoria):
// marca um título a pagar/receber como conferido ou suspeito, com trilha de quem
// e quando. lancamentoId = id do ContaPagar/ContaReceber (= código do Omie).
model LancamentoConferencia {
  id           String   @id @default(cuid())
  tipo         String // "PAGAR" | "RECEBER"
  lancamentoId String
  situacao     String // "CONFERIDO" | "SUSPEITO"
  observacao   String?
  por          String?
  createdAt    DateTime @default(now())
  em           DateTime @updatedAt

  @@unique([tipo, lancamentoId])
  @@index([tipo, situacao])
}

// Vínculo manual de uma NFS-e emitida na prefeitura (SigissWeb/Conchal), que não
// está no Omie, com um projeto/obra do Omie — para somar no faturado da obra.
model NfseConchalVinculo {
  id           String    @id @default(cuid())
  numero       String // NUM_DOCU_FISCAL
  serie        String // SERIE_DOCU_FISCAL
  codProj      String // projeto Omie vinculado (= obra na tela Faturamento). String: o codProj do Omie estoura INT4.
  projetoNome  String?
  valor        Float     @default(0)
  data         DateTime?
  tomadorNome  String?
  descricao    String?
  vinculadoPor String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([numero, serie])
  @@index([codProj])
}

// Cache do snapshot de Faturamento por obra (dados do Omie), pra a tela não
// consultar o Omie (~40s) a cada acesso. Atualizado no botão "Atualizar" e por
// cron 1x/dia. id fixo "default" (linha única).
model FaturamentoCache {
  id           String   @id
  dados        Json
  atualizadoEm DateTime @default(now())
}

// Espelho das Contas a Pagar do Omie (financas/contapagar). Sincronizado
// incrementalmente (só o que mudou) por cron + botão Atualizar. id = codigo_lancamento_omie.
model ContaPagar {
  id                 String    @id // codigo_lancamento_omie (string)
  fornecedorCodigo   String?
  fornecedorNome     String?
  valor              Float     @default(0)
  valorPago          Float     @default(0)
  dataEmissao        DateTime?
  dataVencimento     DateTime?
  dataPrevisao       DateTime?
  numeroDocumento    String? // ex: "RPS 3300293"
  numeroDocFiscal    String? // NF
  numeroParcela      String?
  numeroPedidoCompra String?
  categoriaCodigo    String?
  categoriaNome      String?
  categoriasRateio   Json? // rateio por categoria [{codigo,nome,valor}] quando o título é distribuído
  projetoCodigo      String?
  tipoDocumento      String? // BOL, etc.
  status             String? // ABERTO/PAGO/ATRASADO/VENCIDO/CANCELADO
  observacao         String?
  contaCorrenteId    String?
  chaveNfe           String?
  detalheCarregado   Boolean   @default(false) // se já buscou observação/pedido via detalhe
  dataAlteracaoOmie  DateTime?
  syncedAt           DateTime  @default(now())

  @@index([dataVencimento])
  @@index([status])
  @@index([fornecedorNome])
  @@index([categoriaNome])
}

// Espelho das Contas a Receber do Omie. Fonte: financas/mf (movimentos
// financeiros, cNatureza="R"), que — diferente de financas/contareceber —
// expõe o saldo em aberto (nValAberto) e o valor recebido (nValPago), captando
// os títulos "recebidos parcialmente". id = nCodTitulo. Sincronizado por cron + botão.
model ContaReceber {
  id                String    @id // nCodTitulo (string)
  clienteCodigo     String?
  clienteNome       String?
  valor             Float     @default(0) // nValorTitulo (total do título)
  valorRecebido     Float     @default(0) // nValPago
  saldo             Float     @default(0) // nValAberto (a receber)
  dataEmissao       DateTime?
  dataVencimento    DateTime?
  dataPrevisao      DateTime?
  numeroDocumento   String? // cNumTitulo (ex: "RPS 45")
  numeroDocFiscal   String? // cNumDocFiscal — NF emitida
  numeroParcela     String?
  numeroPedidoVenda String?
  numeroOS          String? // cNumOS
  categoriaCodigo   String?
  categoriaNome     String?
  projetoCodigo     String?
  tipoDocumento     String? // cTipo (NFS, NFE, BOL...)
  status            String? // A VENCER/ATRASADO/RECEBIDO/CANCELADO (do Omie)
  observacao        String?
  contaCorrenteId   String?
  chaveNfe          String?
  detalheCarregado  Boolean   @default(false)
  dataAlteracaoOmie DateTime?
  syncedAt          DateTime  @default(now())

  @@index([dataVencimento])
  @@index([status])
  @@index([clienteNome])
  @@index([categoriaNome])
}

// Estado do sync incremental por entidade do Omie ("contapagar" / "contareceber").
model OmieSyncState {
  id              String    @id // "contapagar"
  ultimoSync      DateTime?
  ultimaAlteracao DateTime? // maior data de alteração já sincronizada
  totalRegistros  Int       @default(0)
  updatedAt       DateTime  @updatedAt
}

model Recebimento {
  id              String            @id @default(cuid())
  pedidoOmieId    String?
  rmItemId        String?
  qtdRecebida     Float
  unidade         String?
  dataRecebimento DateTime          @default(now())
  nfNumero        String?
  nfChave         String?
  nfSerie         String?
  origem          RecebimentoOrigem @default(MANUAL)
  observacao      String?
  createdById     String?
  createdAt       DateTime          @default(now())
  createdBy       User?             @relation(fields: [createdById], references: [id])
  pedidoOmie      PedidoOmie?       @relation(fields: [pedidoOmieId], references: [id])
  rmItem          RMItem?           @relation(fields: [rmItemId], references: [id])

  @@index([pedidoOmieId])
  @@index([rmItemId])
  @@index([dataRecebimento])
}

model Cronograma {
  id             String               @id @default(cuid())
  opNumero       String
  opId           String?
  nomeArquivo    String
  titulo         String
  sharepointPath String               @unique
  dataInicio     DateTime?
  dataFim        DateTime?
  dataBase       DateTime? // Data base (baseline) — referencia do cronograma
  tipoDias       String               @default("DU") // DU = dias uteis, DC = dias corridos
  ultimoSync     DateTime             @default(now())
  ativo          Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  op             OP?                  @relation(fields: [opId], references: [id])
  tarefas        CronogramaTarefa[]
  revisoes       CronogramaRevisao[]
  cobrancas      CronogramaCobranca[]

  @@index([opNumero])
  @@index([ativo])
}

model CronogramaTarefa {
  id                  String                  @id @default(cuid())
  cronogramaId        String
  uidMpp              Int
  nome                String
  departamento        DepartamentoCronograma?
  dataInicioPrevista  DateTime?
  dataFimPrevista     DateTime?
  dataInicioBase      DateTime? // Baseline start (snapshot na data base)
  dataFimBase         DateTime? // Baseline end (snapshot na data base)
  percentualPrevisto  Float                   @default(0)
  percentualRealizado Float                   @default(0)
  qtdePlanejada       Float                   @default(0)
  qtdeRealizada       Float                   @default(0)
  isSummary           Boolean                 @default(false)
  outlineLevel        Int                     @default(0)
  parentUid           Int?
  antecessoraIds      String[]                @default([]) // IDs de tarefas predecessoras (finish-to-start)
  duracaoDias         Int                     @default(0) // Duracao em dias (DU ou DC conforme cronograma)
  dataLiberacao       DateTime? // Data em que a tarefa foi liberada (desbloqueio externo)
  motivoBloqueio      String? // Ex: "Aguardando assinatura do aditivo"
  observacao          String?
  dataRealizacao      DateTime?
  // Execução REAL — não altera as datas previstas/base; o atraso é derivado
  dataInicioReal      DateTime?
  dataFimReal         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  registros           CronogramaRegistro[]
  cronograma          Cronograma              @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)

  @@index([cronogramaId])
  @@index([departamento])
}

model CronogramaRegistro {
  id          String           @id @default(cuid())
  tarefaId    String
  descricao   String
  createdById String
  createdAt   DateTime         @default(now())
  createdBy   User             @relation("CronogramaRegistroCreatedBy", fields: [createdById], references: [id])
  tarefa      CronogramaTarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)

  @@index([tarefaId])
}

// Linha de controle — cada alteracao no cronograma gera uma revisao
model CronogramaRevisao {
  id           String     @id @default(cuid())
  cronogramaId String
  tipo         String // BASELINE_DEFINIDA, TAREFA_ALTERADA, SYNC_SHAREPOINT, DATA_ALTERADA
  descricao    String // Descricao legivel da alteracao
  diff         Json? // { campo, antes, depois } ou snapshot
  createdById  String
  createdAt    DateTime   @default(now())
  cronograma   Cronograma @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  createdBy    User       @relation("CronogramaRevisaoCreatedBy", fields: [createdById], references: [id])

  @@index([cronogramaId])
  @@index([createdAt])
}

// Cobranca por email — cada envio gera um token publico para o setor responder com novas datas
model CronogramaCobranca {
  id             String     @id @default(cuid())
  token          String     @unique @default(cuid())
  cronogramaId   String
  departamento   String
  emailsEnviados String[] // Para quem foi enviado
  tarefaIds      String[] // IDs das tarefas cobradas (atrasadas no momento do envio)
  respondido     Boolean    @default(false)
  respostas      Json? // [{ tarefaId, novaData, comentario }]
  createdById    String
  createdAt      DateTime   @default(now())
  respondidoAt   DateTime?
  respondidoPor  String? // Nome/email de quem respondeu
  cronograma     Cronograma @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  createdBy      User       @relation("CobrancaCreatedBy", fields: [createdById], references: [id])

  @@index([cronogramaId])
  @@index([token])
}

model TarefaPlanejamento {
  id                String        @id @default(cuid())
  titulo            String
  descricao         String?
  opNumero          String?
  opId              String?
  setor             String
  semanaIso         Int
  ano               Int
  status            String        @default("PENDENTE")
  prioridade        String        @default("MEDIA")
  responsavel       String?
  dataPrevista      DateTime?
  dataConcluida     DateTime?
  observacao        String?
  // Tarefa de responsabilidade do CLIENTE (ele fornece/aprova). Cobrança/confirmação
  // por e-mail com resposta de 1 clique (token público, sem login).
  doCliente         Boolean       @default(false)
  clienteNome       String?
  clienteEmail      String?
  clienteToken      String?       @unique
  clienteAvisadoEm  DateTime?
  clienteRespostaEm DateTime?
  clienteResposta   String?
  createdById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdBy         User?         @relation("TarefaPlanejamentoCreatedBy", fields: [createdById], references: [id])
  op                OP?           @relation(fields: [opId], references: [id])
  compromissos      Compromisso[]

  @@index([semanaIso, ano])
  @@index([setor])
  @@index([opId])
  @@index([status])
}

// Matriz de comunicação por setor: contatos (nome+e-mail) que recebem as
// tarefas distribuídas pelo Planejamento. 1 registro por setor (setor único).
model ComunicacaoSetor {
  id        String   @id @default(cuid())
  setor     String   @unique
  contatos  Json     @default("[]") // [{ nome, email }]
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Lista Avançada de Expedição importada do SharePoint (1 por frente). marcasJson
// guarda a tabela de marcas parseada (aba PROJETO). Atualizada a cada revisão.
model ListaExpedicao {
  id               String    @id @default(cuid())
  frente           String    @unique // T36, T94A… (ou OP-94 quando o arquivo não tem prefixo)
  opNumero         String?
  opId             String?
  arquivo          String
  revisao          String?
  itemId           String? // id do arquivo no SharePoint (re-download)
  fileModificado   DateTime?
  hash             String? // sha1 do conteúdo (detectar mudança)
  marcas           Int       @default(0)
  qtdItens         Int       @default(0)
  pesoContratado   Float     @default(0)
  pesoExpedido     Float     @default(0)
  pesoFaltante     Float     @default(0)
  expedidasArquivo Int       @default(0)
  marcasJson       Json      @default("[]")
  importadoEm      DateTime  @default(now())
  importadoPorId   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([opNumero])
}

model NecessidadeSemanal {
  id          String   @id @default(cuid())
  semanaIso   Int
  ano         Int
  opNumero    String
  opId        String?
  setor       String
  descricao   String?
  pesoKg      Float    @default(0)
  prioridade  String   @default("MEDIA")
  status      String   @default("PENDENTE")
  observacao  String?
