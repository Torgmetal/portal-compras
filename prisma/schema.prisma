generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String                @id @default(cuid())
  email                    String                @unique
  name                     String
  password                 String
  setor                    String?
  ativo                    Boolean               @default(true)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  podeAlterarVerba         Boolean               @default(false)
  tipo                     TipoUsuario
  // Troca de senha: força a definição de nova senha só no 1º acesso do
  // funcionário (senha provisória). Depois que ele troca, não volta a exigir
  // (sem expiração periódica). senhaAlteradaEm fica como registro da última troca.
  deveTrocarSenha          Boolean               @default(false)
  senhaAlteradaEm          DateTime?
  // Self-service: quando tipo=FUNCIONARIO, vincula 1:1 ao registro de RH
  funcionarioId            String?               @unique
  funcionario              Funcionario?          @relation("UsuarioFuncionario", fields: [funcionarioId], references: [id])
  lotesHoleriteCriados     LoteHolerite[]        @relation("LoteHoleriteCriadoPor")
  folhasCriadas            FolhaCompetencia[]    @relation("FolhaCriadaPor")
  pontosCriados            PontoCompetencia[]    @relation("PontoCriadaPor")
  aditivos                 Aditivo[]
  ajustesPrazoCriados      AjustePrazo[]         @relation("AjustePrazoCreatedBy")
  auditLogs                AuditLog[]
  consultasEstoqueCriadas  ConsultaEstoque[]     @relation("ConsultaEstoqueCreatedBy")
  consultaItensRespondidos ConsultaEstoqueItem[] @relation("ConsultaItemRespondidoPor")
  cronogramaRegistros      CronogramaRegistro[]  @relation("CronogramaRegistroCreatedBy")
  cronogramaRevisoes       CronogramaRevisao[]   @relation("CronogramaRevisaoCreatedBy")
  cronogramaCobrancas      CronogramaCobranca[]  @relation("CobrancaCreatedBy")
  necessidadesSemanais     NecessidadeSemanal[]  @relation("NecessidadeSemanalCreatedBy")
  notificacoes             Notificacao[]
  opsCriadas               OP[]                  @relation("OPCreatedBy")
  orcamentosCriados        Orcamento[]           @relation("OrcamentoCriadoPor")
  passwordResetTokens      PasswordResetToken[]
  prazoHistoricos          PrazoHistorico[]
  producaoDiarias          ProducaoDiaria[]      @relation("ProducaoDiariaCreatedBy")
  estudosCriados           PropostaEstudo[]      @relation("EstudoCriadoPor")
  rmsCriadas               RM[]                  @relation("RMCreatedBy")
  recebimentos             Recebimento[]
  pedidosRecebidos         PedidoOmie[]          @relation("PedidoRecebidoPor")
  revisoesCriadas          Revisao[]             @relation("RevisaoCreatedBy")
  sharepointSyncs          SharepointSync[]
  solicitacoesCriadas      SolicitacaoVerba[]    @relation("SolicitacaoCreatedBy")
  solicitacoesDecididas    SolicitacaoVerba[]    @relation("SolicitacaoDecididoBy")
  tarefasPlanejamento      TarefaPlanejamento[]  @relation("TarefaPlanejamentoCreatedBy")
  compromissos             Compromisso[]         @relation("CompromissoUser")
  compromissosCriados      Compromisso[]         @relation("CompromissoCriadoPor")
  modulos                  UserModulo[]
  pmpMetas                 PmpMeta[]             @relation("PmpMetaCriador")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Meta {
  id          String   @id @default(cuid())
  modulo      String
  tipo        String
  setor       String   @default("GERAL")
  ano         Int
  mes         Int
  valorMensal Float    @default(0)
  semana1     Float?
  semana2     Float?
  semana3     Float?
  semana4     Float?
  semana5     Float?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([modulo, tipo, setor, ano, mes])
  @@index([modulo, ano])
  @@index([modulo, tipo, ano])
}

model UserModulo {
  id     String @id @default(cuid())
  userId String
  modulo Modulo
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modulo])
  @@index([userId])
}

model OP {
  id                   String               @id @default(cuid())
  numero               String               @unique
  cliente              String
  obra                 String?
  descricao            String?
  status               OPStatus             @default(ABERTA)
  createdById          String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  dataFimPrevista      DateTime?
  dataFimReal          DateTime?
  dataInicio           DateTime?
  clienteCep           String?
  clienteCidade        String?
  clienteCnpj          String?
  clienteContato       String?
  clienteEmail         String?
  clienteEndereco      String?
  clienteIE            String?
  clienteRazaoSocial   String?
  clienteTelefone      String?
  clienteUF            String?
  valorTotalContrato   Float?
  // Definidos na abertura da OP
  estoqueMaterial      String? // "PROPRIO_TORG" | "CLIENTE_TERCEIRO"
  tipoDataBook         String? // "PADRAO_TORG" | "SNQC" | "RELATORIO_ACOMPANHAMENTO"
  aditivos             Aditivo[]
  ajustesPrazo         AjustePrazo[]
  cronogramas          Cronograma[]
  estoqueAlocacoes     EstoqueAlocacao[]
  estoqueReservas      EstoqueReserva[]
  fluxoCaixa           FluxoCaixa[]
  mesApontamentos      MesApontamento[]     @relation("MesApontamentosOP")
  necessidadesSemanais NecessidadeSemanal[]
  createdBy            User                 @relation("OPCreatedBy", fields: [createdById], references: [id])
  itens                OPItem[]
  medicoes             OPMedicao[]
  receitas             OPReceita[]
  orcamentos           Orcamento[]          @relation("OrcamentoOP")
  kickoff              OPKickOff?
  pecasConjunto        PecaConjunto[]
  pedidosOmieAvulsos   PedidoOmie[]
  planejamentosCarga   PlanejamentoCarga[]
  producaoSemanal      ProducaoSemanal[]
  rms                  RM[]
  rmItensDestino       RMItem[]             @relation("RMItemOpDestino")
  revisoes             Revisao[]
  romaneios            Romaneio[]
  tarefasPlanejamento  TarefaPlanejamento[]

  @@index([numero])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdById, status])
}

model ProducaoSemanal {
  id              String   @id @default(cuid())
  semana          String
  dataInicio      DateTime
  dataFim         DateTime
  pesoPrevistoKg  Float    @default(0)
  pesoRealizadoKg Float    @default(0)
  valorPrevisto   Float    @default(0)
  valorRealizado  Float    @default(0)
  opId            String?
  observacao      String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  data            DateTime
  fonte           String?
  setor           String?
  op              OP?      @relation(fields: [opId], references: [id])

  @@unique([data, opId, setor])
  @@index([data])
  @@index([semana])
  @@index([opId])
  @@index([setor])
}

model Romaneio {
  id                String             @id @default(cuid())
  numero            String
  opId              String?
  data              DateTime
  pesoRealKg        Float
  descricao         String?
  observacao        String?
  valorPorKg        Float?
  valorTotal        Float?
  // Destino da carga (vem da entrega definida no Planejamento)
  destino           String?
  // Transportadora (campos livres no romaneio — sem cadastro)
  transportadora    String?
  motorista         String?
  placaVeiculo      String?
  contatoTransporte String?
  // Controle de NF (a própria Expedição emite/registra — controle interno)
  nfStatus          String?            @default("PENDENTE") // PENDENTE | SOLICITADA | EMITIDA
  nfNumero          String?
  nfSerie           String? // série da NF-e (vinda do Omie)
  nfChave           String? // chave de acesso (44 díg., vinda do Omie)
  nfSolicitadaEm    DateTime?
  nfEmitidaEm       DateTime?
  createdById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  planejamentoCarga PlanejamentoCarga?
  op                OP?                @relation(fields: [opId], references: [id])
  itens             RomaneioItem[]

  @@index([opId])
  @@index([data])
}

model RomaneioItem {
  id             String        @id @default(cuid())
  romaneioId     String
  tipo           String
  descricao      String
  pecaConjuntoId String?
  rmItemId       String?
  qtd            Float         @default(1)
  pesoKg         Float?
  observacao     String?
  createdAt      DateTime      @default(now())
  pecaConjunto   PecaConjunto? @relation(fields: [pecaConjuntoId], references: [id])
  rmItem         RMItem?       @relation(fields: [rmItemId], references: [id])
  romaneio       Romaneio      @relation(fields: [romaneioId], references: [id], onDelete: Cascade)

  @@index([romaneioId])
  @@index([pecaConjuntoId])
  @@index([rmItemId])
}

model PlanejamentoCarga {
  id           String                       @id @default(cuid())
  opId         String
  dataPrevista DateTime
  descricao    String?
  status       String                       @default("PLANEJADO")
  romaneioId   String?                      @unique
  createdById  String?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  op           OP                           @relation(fields: [opId], references: [id])
  romaneio     Romaneio?                    @relation(fields: [romaneioId], references: [id])
  itens        PlanejamentoCargaItem[]
  historico    PlanejamentoCargaHistorico[]

  @@index([opId])
  @@index([status])
  @@index([dataPrevista])
}

// Registro de mudanças de uma carga (data, quantidade por item, status).
model PlanejamentoCargaHistorico {
  id        String            @id @default(cuid())
  cargaId   String
  campo     String // "data" | "qtd" | "status" | "criacao"
  descricao String
  de        String?
  para      String?
  userId    String?
  userName  String?
  createdAt DateTime          @default(now())
  carga     PlanejamentoCarga @relation(fields: [cargaId], references: [id], onDelete: Cascade)

  @@index([cargaId])
}

model PlanejamentoCargaItem {
  id                 String            @id @default(cuid())
  planejamentoId     String
  tipo               String
  descricao          String
  pecaConjuntoId     String?
  rmItemId           String?
  qtdPlanejada       Float             @default(1)
  qtdCarregada       Float             @default(0)
  pesoEstimadoKg     Float?
  status             String            @default("PLANEJADO")
  motivoNaoEnvio     String?
  reprogramadoParaId String?
  createdAt          DateTime          @default(now())
  pecaConjunto       PecaConjunto?     @relation(fields: [pecaConjuntoId], references: [id])
  planejamento       PlanejamentoCarga @relation(fields: [planejamentoId], references: [id], onDelete: Cascade)
  rmItem             RMItem?           @relation(fields: [rmItemId], references: [id])

  @@index([planejamentoId])
  @@index([pecaConjuntoId])
  @@index([rmItemId])
  @@index([status])
}

model FluxoCaixa {
  id            String    @id @default(cuid())
  data          DateTime
  tipo          String
  categoria     String
  descricao     String
  valor         Float
  realizado     Boolean   @default(false)
  dataRealizado DateTime?
  opId          String?
  observacao    String?
  // Origem Omie (extrato de conta corrente) — importados pelo /importar-omie.
  origemOmieId  String? // ex: "EXT-<nCodCC>-<nCodLancamento>"; null = lançamento manual
  contaCorrente String? // banco/conta de origem (ex: "Inter")
  contraparte   String? // fornecedor/cliente do movimento (do extrato Omie)
  transferencia Boolean   @default(false) // transferência entre contas próprias
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  op            OP?       @relation(fields: [opId], references: [id])

  @@index([data])
  @@index([tipo])
  @@index([categoria])
  @@index([opId])
  @@index([origemOmieId])
}

model OPMedicao {
  id                String    @id @default(cuid())
  opId              String
  numeroPedidoOmie  String
  codigoPedidoOmie  String?
  descricao         String?
  data              DateTime?
  valorBruto        Float     @default(0)
  valorLiquido      Float?
  status            String?
  etapa             String?
  qtdItens          Int       @default(0)
  ultimoSync        DateTime?
  syncErro          String?
  payload           Json?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tipoDocumento     String    @default("VENDA")
  valorContratado   Float?
  valorFaturadoAuto Float?
  op                OP        @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, numeroPedidoOmie])
  @@index([opId])
}

model OPReceita {
  id                  String   @id @default(cuid())
  opId                String
  ordem               Int      @default(0)
  categoria           String
  descricao           String
  cfop                String?
  codigoServico       String?
  valor               Float
  icmsPct             Float?
  ipiPct              Float?
  pisPct              Float?
  cofinsPct           Float?
  issPct              Float?
  irrfPct             Float?
  csllPct             Float?
  observacao          String?
  enderecoFaturamento String? // endereço de entrega/faturamento da linha (obra com múltiplos endereços)
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  op                  OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@index([opId])
  @@index([categoria])
}

// Kick Off da OP — documento de alinhamento divulgado aos setores no início
// do contrato (1 por OP). Pré-preenchido com dados da OP/estudo; campos que
// não existem no banco (entrega, inspeção, pedido do cliente) são manuais ou
// extraídos do PDF da proposta via IA.
model OPKickOff {
  id                     String          @id @default(cuid())
  opId                   String          @unique
  // Pedido do cliente
  pedidoCompraCliente    String?
  // Entrega
  entregaEndereco        String? // endereço de ENTREGA da obra (≠ endereço fiscal)
  frete                  String? // "TORG" (CIF, por nossa conta) | "CLIENTE" (FOB)
  // Técnica
  padraoPintura          String?
  inspecao               String?
  // Fiscal
  notaRetorno            Boolean         @default(false)
  notaRetornoObs         String?
  fiscalObservacao       String? // como será o faturamento (complementa a tabela de linhas FD)
  // Conteúdo
  escopo                 String? // resumo curto do fornecimento
  escopoIncluso          String? // um item por linha (lista do que ESTÁ incluído)
  escopoExcluso          String? // um item por linha (lista do que NÃO está)
  pontosAtencao          String? // um por linha
  observacoes            String?
  // Cronograma prévio acordado com o cliente (marcos por setor/fase)
  dataEntregaAcordada    DateTime?
  cronograma             Json? // [{fase, data:"YYYY-MM-DD", obs}]
  // Prioridades de fase/peça/entrega (opcional — só obras que têm)
  prioridades            Json? // [{ordem, descricao, data:"YYYY-MM-DD"|null}]
  // Resumo de pesos da planilha comercial (sem valores em R$)
  pesoResumo             Json? // [{descricao, qtd, pesoKg}]
  // Propostas (PDF) + extração IA — comercial e técnica
  propostaPdfUrl         String? // proposta COMERCIAL
  propostaPdfNome        String?
  propostaTecnicaPdfUrl  String?
  propostaTecnicaPdfNome String?
  extraidoIA             Json?
  // Anexos técnicos: PLP (plano de pintura) e documento de inspeção (ITP)
  pinturaPlpUrl          String?
  pinturaPlpNome         String?
  inspecaoArquivoUrl     String?
  inspecaoArquivoNome    String?
  // Fiscal estruturado
  tipoFaturamento        String? // como definido na proposta (medições, eventos, à vista...)
  faturamentoEventos     Json? // [{descricao, percentual, valor, prazoPagamento, medicao, obsNF}]
  retencaoContratual     String? // ex: "5% — liberação após CND"
  segurosObrigatorios    String?
  aceites                KickoffAceite[]
  // Reuniões e divulgação
  kickoffComercialEm     DateTime?
  kickoffSetoresEm       DateTime?
  enviadoPara            String?
  enviadoEm              DateTime?
  createdById            String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  op                     OP              @relation(fields: [opId], references: [id], onDelete: Cascade)
}

// Aceite dos setores ao Kick Off divulgado — cada destinatário recebe um link
// único por e-mail e confirma que está de acordo com as informações.
model KickoffAceite {
  id        String    @id @default(cuid())
  kickoffId String
  tipo      String    @default("GERAL") // GERAL | FISCAL
  email     String
  token     String    @unique
  enviadoEm DateTime  @default(now())
  aceitoEm  DateTime?
  kickoff   OPKickOff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)

  @@index([kickoffId])
}

model OPItem {
  id                String             @id @default(cuid())
  opId              String
  ordem             Int                @default(0)
  descricao         String
  codigoOmie        String?
  unidade           String?
  qtdContratada     Float?
  valorVerba        Float
  faturamentoDireto Boolean            @default(false)
  observacao        String?
  capacidade        String?
  categoria         String
  meses             Int?
  tipo              ItemTipo           @default(VERBA)
  valorPorMes       Float?
  cmcMedio          Float?
  localEstoque      String?
  op                OP                 @relation(fields: [opId], references: [id], onDelete: Cascade)
  rmItens           RMItem[]
  solicitacoesVerba SolicitacaoVerba[]

  @@index([opId])
  @@index([categoria])
}

model Revisao {
  id          String   @id @default(cuid())
  opId        String
  numero      Int
  motivo      String
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("RevisaoCreatedBy", fields: [createdById], references: [id])
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, numero])
  @@index([opId])
}

model Aditivo {
  id          String        @id @default(cuid())
  opId        String
  numero      Int
  descricao   String
  createdById String
  createdAt   DateTime      @default(now())
  createdBy   User          @relation(fields: [createdById], references: [id])
  op          OP            @relation(fields: [opId], references: [id], onDelete: Cascade)
  itens       AditivoItem[]

  @@unique([opId, numero])
  @@index([opId])
}

model AditivoItem {
  id                String             @id @default(cuid())
  aditivoId         String
  ordem             Int                @default(0)
  descricao         String
  codigoOmie        String?
  unidade           String?
  qtdContratada     Float?
  valorVerba        Float
  faturamentoDireto Boolean            @default(false)
  observacao        String?
  capacidade        String?
  categoria         String
  meses             Int?
  tipo              ItemTipo           @default(VERBA)
  valorPorMes       Float?
  cmcMedio          Float?
  localEstoque      String?
  aditivo           Aditivo            @relation(fields: [aditivoId], references: [id], onDelete: Cascade)
  rmItens           RMItem[]
  solicitacoesVerba SolicitacaoVerba[]

  @@index([aditivoId])
  @@index([categoria])
}

model AjustePrazo {
  id              String   @id @default(cuid())
  opId            String
  dataFimAnterior DateTime
  dataFimNova     DateTime
  motivo          String
  createdById     String
  createdAt       DateTime @default(now())
  createdBy       User     @relation("AjustePrazoCreatedBy", fields: [createdById], references: [id])
  op              OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@index([opId])
}

model SolicitacaoVerba {
  id               String                 @id @default(cuid())
  opItemId         String?
  aditivoItemId    String?
  valorAtual       Float
  valorProposto    Float
  justificativa    String
  status           SolicitacaoVerbaStatus @default(PENDENTE)
  observacaoMaster String?
  decididoEm       DateTime?
  decididoById     String?
  createdById      String
  createdAt        DateTime               @default(now())
  aditivoItem      AditivoItem?           @relation(fields: [aditivoItemId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("SolicitacaoCreatedBy", fields: [createdById], references: [id])
  decididoBy       User?                  @relation("SolicitacaoDecididoBy", fields: [decididoById], references: [id])
  opItem           OPItem?                @relation(fields: [opItemId], references: [id], onDelete: Cascade)

  @@index([opItemId])
  @@index([aditivoItemId])
  @@index([status])
}

model RM {
  id                 String            @id @default(cuid())
  numero             String            @unique
  opId               String?
  tipo               String            @default("Material")
  descricao          String
  observacao         String?
  status             RMStatus          @default(ABERTA)
  categoriaCompra    String?
  localEstoque       String?
  createdById        String
  setor              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  categoriasOP       String[]          @default([])
  tipoRM             TipoRM            @default(ENGENHARIA)
  faturamentoDireto  Boolean           @default(false)
  anexos             Anexo[]
  consultasEstoque   ConsultaEstoque[]
  cotacoes           Cotacao[]
  envios             Envio[]
  pedidosFDAtendidos PedidoOmie[]      @relation("PedidoOmieRMAtendida")
  createdBy          User              @relation("RMCreatedBy", fields: [createdById], references: [id])
  op                 OP?               @relation(fields: [opId], references: [id])
  itens              RMItem[]

  @@index([opId])
  @@index([status])
  @@index([createdById])
  @@index([status, createdAt])
  @@index([opId, status])
}

model PedidoOmie {
  id                   String           @id @default(cuid())
  cotacaoId            String?
  fornecedorNome       String
  nCodFor              String?
  cnpj                 String?
  codigoPedido         String?
  numeroPedido         String?
  total                Float            @default(0)
  faturamentoDireto    Boolean          @default(false)
  status               String           @default("CRIADO")
  observacao           String?
  erroOmie             String?
  payload              Json?
  resposta             Json?
  createdById          String?
  createdAt            DateTime         @default(now())
  anexoNome            String?
  anexoUrl             String?
  criadoManualmente    Boolean          @default(false)
  opId                 String?
  categoriaItem        String?
  itensDetalhes        Json?
  rmAtendidaId         String?
  dataEntregaReal      DateTime?
  prazoEntregaPrevisto DateTime?
  statusEntrega        String?
  prazoOriginal        DateTime?
  tokenEntrega         String?          @unique
  itensOmie            Json?
  nfNumero             String?
  nfSerie              String?
  nfChave              String?
  recebidoPorId        String?
  recebidoEm           DateTime?
  recebidoPor          User?            @relation("PedidoRecebidoPor", fields: [recebidoPorId], references: [id])
  cotacao              Cotacao?         @relation(fields: [cotacaoId], references: [id])
  op                   OP?              @relation(fields: [opId], references: [id])
  rmAtendida           RM?              @relation("PedidoOmieRMAtendida", fields: [rmAtendidaId], references: [id])
  prazoHistorico       PrazoHistorico[]
  rmItens              RMItem[]
  recebimentos         Recebimento[]

  @@index([cotacaoId])
  @@index([opId])
  @@index([status])
}

model PrazoHistorico {
  id            String     @id @default(cuid())
  pedidoId      String
  prazoAnterior DateTime?
  prazoNovo     DateTime
  motivo        String?
  alteradoPorId String?
  criadoEm      DateTime   @default(now())
  alteradoPor   User?      @relation(fields: [alteradoPorId], references: [id])
  pedido        PedidoOmie @relation(fields: [pedidoId], references: [id])

  @@index([pedidoId])
}

model RMItem {
  id                     String                  @id @default(cuid())
  rmId                   String
  opItemId               String?
  ordem                  Int                     @default(0)
  descricao              String
  unidade                String
  qtd                    Float
  material               String?
  comprimento            String?
  largura                String?
  peso                   Float?
  pesoLinear             Float?
  codigo                 String?
  tratamento             String?
  observacao             String?
  aditivoItemId          String?
  canceladoEm            DateTime?
  canceladoMotivo        String?
  atendidoEstoqueEm      DateTime?
  atendidoEstoqueQtd     Float?
  atendidoEstoqueObs     String?
  atendidoEstoquePreco   Float?
  atendidoEstoqueTotal   Float?
  status                 RMItemStatus            @default(PENDENTE)
  pedidoOmieId           String?
  codigoOmieEstoque      String?
  destinoEstoque         Boolean                 @default(false)
  opDestinoId            String?
  valorDiaria            Float?
  qtdDias                Int?
  valorTotal             Float?
  consultaEstoqueItens   ConsultaEstoqueItem[]
  cotacaoItens           CotacaoItem[]
  planejamentoCargaItens PlanejamentoCargaItem[]
  aditivoItem            AditivoItem?            @relation(fields: [aditivoItemId], references: [id])
  opDestino              OP?                     @relation("RMItemOpDestino", fields: [opDestinoId], references: [id])
  opItem                 OPItem?                 @relation(fields: [opItemId], references: [id])
  pedidoOmie             PedidoOmie?             @relation(fields: [pedidoOmieId], references: [id])
  rm                     RM                      @relation(fields: [rmId], references: [id], onDelete: Cascade)
  recebimentos           Recebimento[]
  romaneioItens          RomaneioItem[]

  @@index([rmId])
  @@index([opItemId])
  @@index([aditivoItemId])
  @@index([status])
  @@index([pedidoOmieId])
  @@index([status, opDestinoId])
  @@index([rmId, status])
}

model Cotacao {
  id                     String        @id @default(cuid())
  rmId                   String
  fornecedorNome         String
  fornecedorEmail        String?
  nCodOmie               String?
  cnpj                   String?
  faturamento            String        @default("Torg")
  prazoPagamento         String?
  observacao             String?
  total                  Float         @default(0)
  prazoResposta          DateTime?
  recebidaEm             DateTime?
  declinadaEm            DateTime?
  motivoDeclinio         String?
  status                 CotacaoStatus @default(PENDENTE)
  token                  String?       @unique
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  numeroRevisao          Int           @default(0)
  totalProposta          Float?
  solicitadaRevisaoFinal DateTime?
  fornecedorId           String?
  numeroProposta         String?
  anexos                 Anexo[]
  fornecedor             Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  rm                     RM            @relation(fields: [rmId], references: [id], onDelete: Cascade)
  itens                  CotacaoItem[]
  pedidosOmie            PedidoOmie[]

  @@index([rmId])
  @@index([fornecedorId])
  @@index([status])
  @@index([token])
  @@index([status, createdAt])
  @@index([rmId, status])
}

model CotacaoItem {
  id                String    @id @default(cuid())
  cotacaoId         String
  rmItemId          String
  precoUnit         Float
  qtdCotada         Float
  qtdProposta       Float?
  // Abatimento por estoque (consulta respondida pela Produção/Engenharia em barras):
  // qtdPecasCotada = nº de barras/peças LÍQUIDO enviado ao fornecedor;
  // estoqueAbatidoQtd = nº de barras/peças abatidas do estoque. Null = sem abatimento.
  qtdPecasCotada    Float?
  estoqueAbatidoQtd Float?
  icmsPct           Float?
  ipiPct            Float?
  observacao        String?
  vencedor          Boolean   @default(false)
  prazoEntrega      DateTime?
  semEstoque        Boolean   @default(false)
  cotacao           Cotacao   @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rmItem            RMItem    @relation(fields: [rmItemId], references: [id])

  @@index([cotacaoId])
  @@index([rmItemId])
  @@index([cotacaoId, vencedor])
  @@index([rmItemId, vencedor])
}

model Envio {
  id              String   @id @default(cuid())
  rmId            String
  fornecedorNome  String
  fornecedorEmail String
  data            DateTime @default(now())
  status          String   @default("Enviado")
  rm              RM       @relation(fields: [rmId], references: [id], onDelete: Cascade)

  @@index([rmId])
}

model Anexo {
  id          String   @id @default(cuid())
  cotacaoId   String?
  rmId        String?
  nomeArquivo String
  blobUrl     String
  tamanho     Int
  tipo        String
  uploadedAt  DateTime @default(now())
  cotacao     Cotacao? @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rm          RM?      @relation(fields: [rmId], references: [id], onDelete: Cascade)

  @@index([cotacaoId])
  @@index([rmId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Fornecedor {
  id               String    @id @default(cuid())
  razaoSocial      String
  nomeFantasia     String?
  cnpj             String?
  email            String
  emailsAdicionais String[]
  telefone         String?
  contato          String?
  cidade           String?
  uf               String?
  categorias       String[]
  observacao       String?
  nCodOmie         String?
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cotacoes         Cotacao[]

  @@index([ativo])
}

model EmailNotificacao {
  id        String   @id @default(cuid())
  email     String
  nome      String?
  eventos   String[]
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
}

model CategoriaFornecedor {
  id        String   @id @default(cuid())
  codigo    String   @unique
  label     String
  color     String   @default("slate")
  ordem     Int      @default(100)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notificacao {
  id           String          @id @default(cuid())
  tipo         NotificacaoTipo
  titulo       String
  mensagem     String
  link         String?
  dados        Json?
  origemUserId String?
  lida         Boolean         @default(false)
  lidaEm       DateTime?
  createdAt    DateTime        @default(now())
  origemUser   User?           @relation(fields: [origemUserId], references: [id])

  @@index([lida])
  @@index([createdAt])
  @@index([tipo])
}

model ConsultaEstoque {
  id           String                @id @default(cuid())
  rmId         String
  status       String                @default("ENVIADA")
  mensagem     String?
  createdById  String
  respondidoEm DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  createdBy    User                  @relation("ConsultaEstoqueCreatedBy", fields: [createdById], references: [id])
  rm           RM                    @relation(fields: [rmId], references: [id], onDelete: Cascade)
  itens        ConsultaEstoqueItem[]

  @@index([rmId])
  @@index([status])
}

model ConsultaEstoqueItem {
  id              String          @id @default(cuid())
  consultaId      String
  rmItemId        String
  resposta        String?
  qtdDisponivel   Float?
  observacao      String?
  respondidoPorId String?
  respondidoEm    DateTime?
  consulta        ConsultaEstoque @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  respondidoPor   User?           @relation("ConsultaItemRespondidoPor", fields: [respondidoPorId], references: [id])
  rmItem          RMItem          @relation(fields: [rmItemId], references: [id])

  @@unique([consultaId, rmItemId])
  @@index([rmItemId])
}

model Setor {
  id           String        @id @default(cuid())
  nome         String        @unique
  sigla        String?
  cor          String?
  gestorId     String?
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  funcionarios Funcionario[] @relation("FuncionarioSetor")
  gestor       Funcionario?  @relation("GestorSetor", fields: [gestorId], references: [id])
  vagas        Vaga[]
}

model Cargo {
  id           String             @id @default(cuid())
  nome         String
  nivel        String?
  categoria    String?
  salarioBase  Float?
  cbo          String?
  ativo        Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  competencias CargoCompetencia[]
  funcionarios Funcionario[]
  vagas        Vaga[]

  @@index([nivel])
  @@index([categoria])
}

model Funcionario {
  id                    String                    @id @default(cuid())
  nome                  String
  cpf                   String?                   @unique
  pis                   String? // PIS/PASEP — usado p/ casar marcações do ACJEF (ponto)
  empresa               String? // empresa empregadora (TORG Metal / VMI) — holerite/ponto multi-CNPJ
  centroCusto           String? // classificação de custo: MOD, MOI, DP, TST, TERCEIRO...
  banco                 String? // dados bancários (cadastro completo)
  agencia               String?
  conta                 String?
  pixChave              String?
  rg                    String?
  dataNascimento        DateTime?
  email                 String?
  telefone              String?
  endereco              String?
  cidadeUF              String?
  matricula             String?                   @unique
  dataAdmissao          DateTime
  dataDemissao          DateTime?
  setorId               String
  cargoId               String
  salario               Float?
  tipoContrato          String                    @default("CLT")
  jornadaHoras          Int                       @default(44)
  turno                 String?
  status                String                    @default("ATIVO")
  ativo                 Boolean                   @default(true)
  foto                  String?
  observacao            String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  categoriaDesligamento String?
  motivoDesligamento    String?
  tipoDesligamento      String?
  afastamentos          Afastamento[]
  dependentes           Dependente[]
  documentos            Documento[]
  ferias                Ferias[]
  holerites             Holerite[]
  folhaItens            FolhaItem[]
  pontoItens            PontoItem[]
  usuario               User?                     @relation("UsuarioFuncionario")
  cargo                 Cargo                     @relation(fields: [cargoId], references: [id])
  setor                 Setor                     @relation("FuncionarioSetor", fields: [setorId], references: [id])
  beneficios            FuncionarioBeneficio[]
  competencias          FuncionarioCompetencia[]
  pontos                Ponto[]
  setoresGeridos        Setor[]                   @relation("GestorSetor")
  treinamentos          TreinamentoParticipante[]

  @@index([setorId])
  @@index([cargoId])
  @@index([status])
  @@index([ativo])
  @@index([dataDemissao])
}

model Dependente {
  id             String      @id @default(cuid())
  funcionarioId  String
  nome           String
  parentesco     String
  dataNascimento DateTime?
  cpf            String?
  createdAt      DateTime    @default(now())
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@index([funcionarioId])
}

model Ponto {
  id               String      @id @default(cuid())
  funcionarioId    String
  data             DateTime    @db.Date
  entrada1         String?
  saida1           String?
  entrada2         String?
  saida2           String?
  horasTrabalhadas Float?
  horasExtras      Float       @default(0)
  bancoHoras       Float       @default(0)
  tipo             String      @default("NORMAL")
  observacao       String?
  createdAt        DateTime    @default(now())
  funcionario      Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, data])
  @@index([data])
}

model Ferias {
  id                 String      @id @default(cuid())
  funcionarioId      String
  periodoAquisInicio DateTime
  periodoAquisFim    DateTime
  dataInicio         DateTime?
  dataFim            DateTime?
  diasGozo           Int?
  diasVendidos       Int         @default(0)
  valorEstimado      Float? // valor líquido estimado (bruto − descontos) — snapshot
  descontos          Float       @default(0) // descontos manuais (empréstimos etc.)
  periodoIndice      Int? // nº do período aquisitivo (0 = 1º ano) inferido da dataInicio vs. admissão. Lançar uma férias retroativa avança o período: as anteriores contam como gozadas.
  status             String      @default("PENDENTE")
  observacao         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  funcionario        Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@index([funcionarioId])
  @@index([status])
}

model Beneficio {
  id           String                 @id @default(cuid())
  nome         String                 @unique
  tipo         String
  valorPadrao  Float?
  ativo        Boolean                @default(true)
  createdAt    DateTime               @default(now())
  funcionarios FuncionarioBeneficio[]
}

model FuncionarioBeneficio {
  id            String      @id @default(cuid())
  funcionarioId String
  beneficioId   String
  valorMensal   Float
  ativo         Boolean     @default(true)
  dataInicio    DateTime    @default(now())
  dataFim       DateTime?
  beneficio     Beneficio   @relation(fields: [beneficioId], references: [id])
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, beneficioId])
}

model Competencia {
  id           String                   @id @default(cuid())
  nome         String                   @unique
  categoria    String?
  descricao    String?
  createdAt    DateTime                 @default(now())
  cargos       CargoCompetencia[]
  funcionarios FuncionarioCompetencia[]
}

model CargoCompetencia {
  id            String      @id @default(cuid())
  cargoId       String
  competenciaId String
  nivelEsperado Int         @default(3)
  cargo         Cargo       @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  competencia   Competencia @relation(fields: [competenciaId], references: [id], onDelete: Cascade)

  @@unique([cargoId, competenciaId])
}

model FuncionarioCompetencia {
  id            String      @id @default(cuid())
  funcionarioId String
  competenciaId String
  nivelAtual    Int         @default(1)
  avaliadoEm    DateTime?
  avaliadoPor   String?
  competencia   Competencia @relation(fields: [competenciaId], references: [id], onDelete: Cascade)
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, competenciaId])
}

model Documento {
  id               String       @id @default(cuid())
  nome             String
  tipo             String
  categoria        String
  descricao        String?
  funcionarioId    String?
  dataEmissao      DateTime?
  dataValidade     DateTime?
  orgaoEmissor     String?
  numeroDocumento  String?
  observacao       String?
  ativo            Boolean      @default(true)
  // Arquivo anexado (Vercel Blob) + cópia de backup no SharePoint (controle ISO)
  arquivoUrl       String? // URL do Blob (privada: só servida via proxy autenticado)
  arquivoNome      String?
  arquivoTamanho   Int?
  arquivoTipo      String?
  sharepointUrl    String? // webUrl da cópia no SharePoint (backup ISO)
  // Quando setado, o arquivo é servido direto do SharePoint (sem cópia no Blob) —
  // usado pela importação em massa dos documentos de RH já existentes no SP.
  sharepointItemId String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  funcionario      Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@index([funcionarioId])
  @@index([categoria])
  @@index([dataValidade])
  @@index([tipo])
}

// Lote de importação de holerites — um PDF multipágina (1 holerite/página) que a
// contabilidade envia por competência. Mantém o arquivo original e rastreia o split.
model LoteHolerite {
  id                  String     @id @default(cuid())
  competencia         String // "AAAA-MM" (ex: "2026-05")
  empresa             String? // razão social predominante (TORG Metal, VMI...)
  cnpj                String?
  arquivoOriginalUrl  String? // Blob privado do PDF completo enviado
  arquivoOriginalNome String?
  totalPaginas        Int        @default(0)
  criadoPorId         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  criadoPor           User?      @relation("LoteHoleriteCriadoPor", fields: [criadoPorId], references: [id])
  holerites           Holerite[]

  @@index([competencia])
}

// Holerite individual de um funcionário numa competência. Arquivo (página única)
// no Blob privado, servido via proxy autenticado (mesmo padrão de Documento).
model Holerite {
  id             String        @id @default(cuid())
  funcionarioId  String
  loteId         String?
  competencia    String // "AAAA-MM"
  empresa        String?
  tipo           String        @default("MENSAL") // MENSAL | DECIMO_TERCEIRO | FERIAS | RESCISAO
  valorLiquido   Float? // parse best-effort do PDF
  arquivoUrl     String? // Blob do PDF (página individual OU o PDF completo do lote)
  arquivoNome    String?
  arquivoTamanho Int?
  pagina         Int? // quando arquivoUrl é o PDF completo, a página deste holerite (1-based)
  status         String        @default("PENDENTE") // PENDENTE | ENVIADO | VISUALIZADO | CONFIRMADO
  enviadoEm      DateTime?
  visualizadoEm  DateTime?
  confirmadoEm   DateTime?
  confirmadoIp   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  funcionario    Funcionario   @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  lote           LoteHolerite? @relation(fields: [loteId], references: [id], onDelete: SetNull)

  @@unique([funcionarioId, competencia, tipo])
  @@index([competencia])
  @@index([status])
  @@index([funcionarioId])
}

// Folha de Pagamento — substitui a planilha de fechamento. Uma FolhaCompetencia
// por mês (AAAA-MM); cada FolhaItem é um funcionário com snapshot do cadastro +
// os valores digitados pelo RH. Os derivados (Base INSS, FGTS, INSS Patronal...)
// são calculados em lib/folha-calc.js (não persistidos — fonte única de cálculo).
model FolhaCompetencia {
  id          String      @id @default(cuid())
  competencia String      @unique // "AAAA-MM"
  status      String      @default("ABERTA") // ABERTA | FECHADA
  criadoPorId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  criadoPor   User?       @relation("FolhaCriadaPor", fields: [criadoPorId], references: [id])
  itens       FolhaItem[]

  @@index([competencia])
}

model FolhaItem {
  id            String           @id @default(cuid())
  folhaId       String
  funcionarioId String?
  // Snapshot do cadastro no momento da competência (cadastro muda mês a mês)
  nome          String
  cpf           String?
  empresa       String?
  centroCusto   String?
  tipoContrato  String           @default("CLT") // CLT | PJ
  salarioBase   Float            @default(0)
  // Digitados pelo RH (vêm do sistema de folha)
  horasExtras   Float            @default(0)
  adicionais    Float            @default(0)
  descontos     Float            @default(0)
  inss          Float            @default(0)
  irrf          Float            @default(0)
  liquido       Float            @default(0)
  vr            Float            @default(0)
  ifood         Float            @default(0)
  kr            Float            @default(0)
  rescisao      Float            @default(0)
  observacao    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  folha         FolhaCompetencia @relation(fields: [folhaId], references: [id], onDelete: Cascade)
  funcionario   Funcionario?     @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)

  @@unique([folhaId, funcionarioId])
  @@index([folhaId])
  @@index([empresa])
  @@index([centroCusto])
}

// Controle de Ponto — importa o arquivo ACJEF (Portaria 1510) por competência.
// PontoItem = um funcionário no mês, com as marcações importadas (Json, referência)
// e os totais que o RH confere/preenche pra contabilidade.
model PontoCompetencia {
  id          String      @id @default(cuid())
  competencia String      @unique // "AAAA-MM"
  empresa     String?
  status      String      @default("ABERTA") // ABERTA | FECHADA
  criadoPorId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  criadoPor   User?       @relation("PontoCriadaPor", fields: [criadoPorId], references: [id])
  itens       PontoItem[]

  @@index([competencia])
}

model PontoItem {
  id               String           @id @default(cuid())
  pontoId          String
  funcionarioId    String?
  pisArquivo       String // chave do arquivo: PIS (ACJEF) ou CPF-dígitos (PDF Secullum)
  cpfArquivo       String? // CPF como veio no PDF Secullum (dígitos) — casa com o cadastro
  empresa          String? // empresa do arquivo (TORG/VMI) — multi-empresa por competência
  nome             String? // preenchido quando casa/mapeia o funcionário
  marcacoes        Json? // [{ data, marcacoes[], raw }] — referência (ACJEF)
  diario           Json? // espelho diário do PDF Secullum: { totais{min}, dias[{data,batidas,faixas}] }
  pdfUrl           String? // Blob do PDF Secullum COMPLETO (a página do funcionário é extraída sob demanda)
  pagina           Int? // nº da página deste funcionário dentro do PDF completo (1-based)
  origem           String          @default("MANUAL") // MANUAL | ACJEF | SECULLUM_PDF
  horasNormais     Float            @default(0)
  horasExtras50    Float            @default(0)
  horasExtras60    Float            @default(0)
  horasExtras80    Float            @default(0)
  horasExtras100   Float            @default(0)
  horasExtras150   Float            @default(0)
  faltas           Float            @default(0)
  atrasos          Float            @default(0)
  adicionalNoturno Float            @default(0)
  dsr              Float            @default(0)
  ajudaCusto       Float            @default(0)
  observacao       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  ponto            PontoCompetencia @relation(fields: [pontoId], references: [id], onDelete: Cascade)
  funcionario      Funcionario?     @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)

  @@unique([pontoId, pisArquivo])
  @@index([pontoId])
  @@index([funcionarioId])
}

// Mural do portal do funcionário: comunicados/avisos que o RH publica para todos
// (opcionalmente disparados por e-mail). Sem relações — nomes denormalizados.
model MuralAviso {
  id                 String    @id @default(cuid())
  titulo             String
  corpo              String
  fixado             Boolean   @default(false)
  emailEnviadoEm     DateTime?
  emailDestinatarios Int?
  criadoPorId        String?
  criadoPorNome      String?
  ativo              Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([ativo, createdAt])
}

// Sugestões/feedback que o funcionário envia para o RH (portal /meu-rh).
model FeedbackRH {
  id              String    @id @default(cuid())
  funcionarioId   String?
  funcionarioNome String?
  anonimo         Boolean   @default(false)
  categoria       String? // SUGESTAO | RECLAMACAO | ELOGIO | DUVIDA | OUTRO
  mensagem        String
  status          String    @default("NOVO") // NOVO | LIDO | RESOLVIDO
  lidoEm          DateTime?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
}

// Painel de Relatórios — v1: relatório de status com fotos p/ o cliente, no
// layout padrão Torg (linha do Data Book). blocos = JSON [{ id, titulo,
// descricao, fotos: [{ url, legenda }] }]. Sem relações — vínculo à OP é só snapshot.
model RelatorioStatus {
  id            String   @id @default(cuid())
  numero        Int? // sequencial global (REL-001) — atribuído na criação
  opId          String?
  opNumero      String? // OP.numero é texto ("067", "T60B") — snapshot
  cliente       String?
  obra          String?
  titulo        String
  resumo        String?
  blocos        Json     @default("[]")
  status        String   @default("RASCUNHO") // RASCUNHO | EMITIDO
  token         String?  @unique // link público de aceite do cliente
  aceitoEm      DateTime?
  aceitoNome    String?
  aceitoIp      String?
  envios        Json     @default("[]") // histórico: [{ para, cc, porNome, em }]
  criadoPorId   String?
  criadoPorNome String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([opId])
}

// Orçamento de Serviço (Comercial → Central de Orçamentos) — separado do
// Orcamento de estrutura. servicos = JSON de chaves (CORTE_FURACAO, JATEAMENTO,
// PINTURA, SOLDA). Criado por SQL; abas da proposta virão depois.
model OrcamentoServico {
  id            String   @id @default(cuid())
  numero        Int? // sequencial (OS-001)
  cliente       String
  obra          String?
  contato       String?
  email         String?
  telefone      String?
  endereco      String?
  servicos      Json     @default("[]")
  composicao    Json     @default("{}") // por serviço: { CORTE_FURACAO: { linhas: [...] }, ... }
  arquivos      Json     @default("[]") // arquivos do cliente: [{ url, nome, tamanho, tipo }]
  status        String   @default("RASCUNHO")
  valor         Float?
  observacoes   String?
  diasPagamento Int? // legado — usar pagamentoPrazo (texto livre)
  pagamentoPrazo String? // prazo de pagamento livre: "15", "28/42", "30/60"…
  inclusos      Json? // lista custom de inclusos (null = padrão)
  exclusos      Json? // lista custom de exclusos (null = padrão)
  lotes         Json? // lotes de entrega: [{ id, nome, local, data, itens:[{descricao,qtd,unidade}] }]
  revisao       Int      @default(0) // revisão atual (R00, R01…)
  revisoes      Json     @default("[]") // histórico: [{ num, data, motivo }]
  enviadoEm     DateTime? // 1º envio ao cliente
  envios        Json     @default("[]") // log de envios: [{ data, para, cc, revisao, porNome }]
  consolidadaEm DateTime? // proposta consolidada (trava edição; ganha tarja)
  aceiteToken   String?   @unique // token do link público de aceite do cliente
  aceiteEnviadoEm DateTime? // quando o link de aceite foi enviado
  aceitoEm      DateTime? // cliente aceitou/assinou
  aceitoNome    String? // nome de quem aceitou
  aceitoDoc     String? // RG/CPF de quem aceitou
  aceitoIp      String? // IP do aceite
  opCriadaId    String? // OP gerada a partir desta proposta aceita
  opId          String?
  criadoPorId   String?
  criadoPorNome String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
}

// Configuração de custo-hora por setor (Comercial) — base do "valor por hora"
// das propostas de serviço. Singleton (id="default"). setores = JSON
// [{ id, nome, empresa, faturaHora, salarios, mod, headcount, horasMes, cifDireto }].
// Overhead a ratear = folha dos setores que NÃO faturam (ADM) + outrosCustos
// (custos operacionais não-folha da DRE: material auxiliar, energia, gás, etc.).
model ConfigCustoHora {
  id                String   @id
  fatorEncargos     Float    @default(1.8)
  custoTotalMensal  Float?
  criterioRateio    String   @default("MOD") // MOD | HEADCOUNT | HORAS
  margemPct         Float    @default(30) // lucro sobre o custo
  impostosVendaPct  Float    @default(15) // ISS + PIS/COFINS sobre a venda (Lucro Real)
  horasDia          Float    @default(8.75) // jornada: horas/dia × dias × aproveitamento = horas/pessoa
  diasUteis         Float    @default(22)
  ocupacaoPct       Float    @default(8) // absenteísmo % (faltas) — horas = pessoas × hd × dias × (1 − ocupacaoPct/100)
  setores           Json     @default("[]")
  outrosCustos      Json     @default("[]") // overhead não-folha: [{ id, nome, valor }] (R$/mês)
  atualizadoPorNome String?
  updatedAt         DateTime @updatedAt @default(now())
}

// Portal da Qualidade — Módulo 1 (Controle de Documentos). Espelha o padrão dos
// documentos de RH (arquivo no Blob privado + backup ISO no SharePoint + proxy
// de download), com camada de VALIDAÇÃO da informação e amarração a norma +
// validade. Status (vigente/vencendo/vencido) é SEMPRE calculado (lib/qualidade-status).
model DocumentoQualidade {
  id               String    @id @default(cuid())
  nome             String
  categoria        String // EQUIPAMENTOS | FUNCIONARIOS | SISTEMA | INSPETORES
  tipo             String? // tipo específico (MTC, ASO, calibração, WPS...)
  norma            String? // AWS D1.1 · NR-35 · ISO 2808 · NBR 16775
  vinculo          String? // texto livre: OP-083 · Soldador João · Munck 01 · TORG
  opNumero         String? // vínculo estruturado opcional (alimenta o Data Book)
  numeroCorrida    String? // heat — certificados de material (rastreabilidade)
  numeroDocumento  String? // nº do certificado (ex.: importação CMR)
  fornecedor       String? // fornecedor do material (importação CMR)
  importRef        String? // índice na planilha de origem (dedupe do import, em código)
  dataEmissao      DateTime?
  dataValidade     DateTime? // null = sem validade
  responsavel      String?
  observacao       String?
  origem           String    @default("registro_manual") // registro_manual | importacao_planilha
  // Validação da informação (camada de revisão antes de valer no data book)
  validado         Boolean   @default(false)
  validadoPorId    String?
  validadoEm       DateTime?
  // Arquivo (Vercel Blob privado) + backup ISO no SharePoint (mesmo padrão do RH)
  arquivoUrl       String?
  arquivoNome      String?
  arquivoTamanho   Int?
  arquivoTipo      String?
  sharepointUrl    String? // webUrl da cópia/origem no SharePoint
  sharepointItemId String? // item do SharePoint servido via proxy (1 PDF de faixa pode atender vários docs)
  ativo            Boolean   @default(true) // soft delete
  invalidadoMotivo String?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([categoria])
  @@index([dataValidade])
  @@index([opNumero])
  @@index([validado])
  @@index([ativo])
  @@index([importRef])
}

// Portal da Qualidade — Módulo 2 (Data Book / dossiê de qualidade por OP).
// Uma por OP, com as 20 seções (template em lib/databook-secoes). Seções de
// fonte "modulo1" puxam documentos do Controle de Documentos pelo vínculo de OP.
model DataBookQualidade {
  id               String               @id @default(cuid())
  opNumero         String               @unique
  opId             String?
  cliente          String?
  obra             String?
  pesoTotalKg      Float?
  pecas            Int?
  tipo             String? // herda de OP.tipoDataBook: PADRAO_TORG | SNQC | RELATORIO_ACOMPANHAMENTO
  observacao       String?
  status           String               @default("EM_MONTAGEM") // EM_MONTAGEM | EMITIDO | ENVIADO_CLIENTE | ACEITO
  emitidoEm        DateTime?
  // Envio e aceite pelo cliente (link público por token, sem login)
  tokenCliente     String?              @unique
  clienteEmail     String?
  enviadoClienteEm DateTime?
  aceiteEm         DateTime?
  aceiteNome       String?
  aceiteIp         String?
  criadoPorId      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  secoes           DataBookSecao[]
  aprovacoes       DataBookAprovacao[]
  assinaturas      DataBookAssinatura[]

  @@index([opNumero])
}

// Cadeia sequencial de assinaturas do data book (assinatura digital por link/e-mail,
// sem login). Ordem: 1 Elaborador → 2 Inspetor → 3 Resp. Técnico → 4 Cliente.
// Cada etapa recebe um e-mail com link; ao assinar (digita o nome), envia a próxima.
model DataBookAssinatura {
  id           String            @id @default(cuid())
  dataBookId   String
  ordem        Int // 1..4
  papel        String // ELABORADOR | INSPETOR | RESP_TECNICO | CLIENTE
  nome         String? // pré-preenchido (RT) ou definido na configuração
  email        String?
  token        String            @unique
  status       String            @default("PENDENTE") // PENDENTE | ENVIADO | ASSINADO
  enviadoEm    DateTime?
  assinadoEm   DateTime?
  assinadoNome String?
  ip           String?
  criadoEm     DateTime          @default(now())
  dataBook     DataBookQualidade @relation(fields: [dataBookId], references: [id], onDelete: Cascade)

  @@unique([dataBookId, ordem])
  @@index([dataBookId])
}

// Aprovação interna do data book (inspetor + envolvidos) antes do envio ao cliente.
model DataBookAprovacao {
  id         String            @id @default(cuid())
  dataBookId String
  userId     String?
  nome       String
  papel      String? // INSPETOR | QUALIDADE | RESP_TECNICO | OUTRO
  aprovadoEm DateTime          @default(now())
  dataBook   DataBookQualidade @relation(fields: [dataBookId], references: [id], onDelete: Cascade)

  @@unique([dataBookId, userId])
  @@index([dataBookId])
}

// Auditorias externas — registra a solicitação do cliente e os documentos que serão
// compartilhados com ele num portal público (link por token, sem login).
model Auditoria {
  id                 String         @id @default(cuid())
  empresa            String // empresa do cliente/auditor
  contato            String? // pessoa de contato no cliente
  titulo             String? // ex.: "Auditoria de Qualificação 2026"
  mensagemBoasVindas String?
  capaUrl            String? // foto de capa do hero do portal (Blob)
  dataBookModeloUrl  String? // PDF de Data Book modelo (exemplo p/ o cliente ver)
  checklistJson      Json? // status dos requisitos do GQ-FQ-003 { reqId: status }
  solicitacoes       String? // o que o cliente pediu (texto / e-mail colado)
  token              String?        @unique
  status             String         @default("RASCUNHO") // RASCUNHO | PUBLICADO
  publicadoEm        DateTime?
  clienteEmail       String?
  enviadoEmailEm     DateTime?
  primeiroAcessoEm   DateTime?
  ultimoAcessoEm     DateTime?
  criadoPorId        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  documentos         AuditoriaDoc[]

  @@index([status])
}

model AuditoriaDoc {
  id               String    @id @default(cuid())
  auditoriaId      String
  tipo             String    @default("EVIDENCIA") // SOLICITACAO (pedido do cliente) | EVIDENCIA (compartilhado)
  secao            String? // área do GQ-FQ-003 (aba no portal)
  requisito        String? // id do requisito/linha do GQ-FQ-003 que o documento atende
  nome             String
  arquivoUrl       String?
  arquivoTipo      String?
  arquivoTamanho   Int?
  sharepointItemId String?
  documentoId      String? // vínculo opcional a um DocumentoQualidade existente
  createdAt        DateTime  @default(now())
  auditoria        Auditoria @relation(fields: [auditoriaId], references: [id], onDelete: Cascade)

  @@index([auditoriaId])
}

// ── Portal de Apresentação ao Cliente (Compras) ──────────────────
// Biblioteca fixa de documentos institucionais da Torg (cadastra 1x, reusa em
// toda apresentação): cadastrais, portfólio, etc.
model DocumentoInstitucional {
  id             String   @id @default(cuid())
  tipo           String   @default("CADASTRAL") // CADASTRAL | PORTFOLIO | OUTRO
  nome           String
  arquivoUrl     String
  arquivoTipo    String?
  arquivoTamanho Int?
  ordem          Int      @default(0)
  ativo          Boolean  @default(true)
  criadoPorId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tipo])
  @@index([ativo])
}

// Página de apresentação personalizada por cliente (link público por token).
model ApresentacaoCliente {
  id                    String            @id @default(cuid())
  contato               String // nome da pessoa
  empresa               String // empresa onde trabalha
  mensagemBoasVindas    String?
  capaUrl               String? // imagem de capa do hero (Blob)
  clienteEmail          String?
  docsInstitucionaisIds Json? // ids da biblioteca a incluir (null/vazio = todos os ativos)
  token                 String?           @unique
  status                String            @default("RASCUNHO") // RASCUNHO | PUBLICADO
  publicadoEm           DateTime?
  enviadoEmailEm        DateTime?
  primeiroAcessoEm      DateTime?
  ultimoAcessoEm        DateTime?
  acessos               Int               @default(0)
  criadoPorId           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  documentos            ApresentacaoDoc[]

  @@index([status])
}

// Documentos extras específicos de uma apresentação (além da biblioteca fixa).
model ApresentacaoDoc {
  id             String              @id @default(cuid())
  apresentacaoId String
  tipo           String              @default("OUTRO") // CADASTRAL | PORTFOLIO | OUTRO
  nome           String
  arquivoUrl     String
  arquivoTipo    String?
  arquivoTamanho Int?
  ordem          Int                 @default(0)
  createdAt      DateTime            @default(now())
  apresentacao   ApresentacaoCliente @relation(fields: [apresentacaoId], references: [id], onDelete: Cascade)

  @@index([apresentacaoId])
}

model DataBookSecao {
  id           String             @id @default(cuid())
  dataBookId   String
  numero       String // "01".."20"
  titulo       String
  norma        String?
  fonte        String // sistema | upload | modulo1 | entrada_a | misto
  estado       String             @default("PENDENTE") // PENDENTE | ANEXADO | NA
  observacao   String?
  conteudoJson Json? // conteúdo gerado no portal (ex.: tabela do PIT da §10)
  ordem        Int
  dataBook     DataBookQualidade  @relation(fields: [dataBookId], references: [id], onDelete: Cascade)
  documentos   DataBookSecaoDoc[]

  @@unique([dataBookId, numero])
  @@index([dataBookId])
}

// Vínculo de um documento do Módulo 1 a uma seção do data book. documentoId
// referencia DocumentoQualidade (sem FK p/ não exigir back-relation; resolvido na API).
model DataBookSecaoDoc {
  id          String        @id @default(cuid())
  secaoId     String
  documentoId String
  createdAt   DateTime      @default(now())
  secao       DataBookSecao @relation(fields: [secaoId], references: [id], onDelete: Cascade)

  @@unique([secaoId, documentoId])
  @@index([secaoId])
  @@index([documentoId])
}

model Vaga {
  id                        String    @id @default(cuid())
  titulo                    String
  setorId                   String
  cargoId                   String?
  quantidade                Int       @default(1)
  prioridade                String    @default("NORMAL")
  tipo                      String    @default("CLT")
  nivelCargo                String?
  justificativa             String?
  requisitos                String?
  salarioFaixa              String?
  solicitanteId             String?
  dataAbertura              DateTime  @default(now())
  status                    String    @default("SOLICITADA")
  dataAprovacao             DateTime?
  dataFechamento            DateTime?
  custoRecrutamento         Float?
  observacaoRH              String?
  funcionarioContratadoNome String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  cargo                     Cargo?    @relation(fields: [cargoId], references: [id])
  setor                     Setor     @relation(fields: [setorId], references: [id])

  @@index([setorId])
  @@index([status])
  @@index([dataAbertura])
}

model Afastamento {
  id            String      @id @default(cuid())
  funcionarioId String
  dataInicio    DateTime
  dataFim       DateTime?
  diasAfastado  Int?
  natureza      String
  categoriaCID  String?
  status        String      @default("EM_ANDAMENTO")
  inss          Boolean     @default(false)
  observacao    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@index([funcionarioId])
  @@index([natureza])
  @@index([dataInicio])
  @@index([status])
}

model AcidenteTrabalho {
  id              String    @id @default(cuid())
  data            DateTime
  hora            String?
  setorId         String?
  obra            String?
  tipo            String
  gravidade       String    @default("LEVE")
  diasPerdidos    Int       @default(0)
  funcionarioNome String?
  funcionarioId   String?
  descricao       String
  causaRaiz       String?
  parteCorpo      String?
  agenteRisco     String?
  catEmitida      Boolean   @default(false)
  catNumero       String?
  acaoCorretiva   String?
  responsavelAcao String?
  prazoAcao       DateTime?
  acaoConcluida   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([data])
  @@index([tipo])
  @@index([setorId])
}

model Treinamento {
  id             String                    @id @default(cuid())
  titulo         String
  tipo           String
  nrRelacionada  String?
  descricao      String?
  instrutor      String?
  local          String?
  dataInicio     DateTime
  dataFim        DateTime?
  cargaHoraria   Float
  validadeMeses  Int?
  custo          Float?
  certificadoUrl String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  participantes  TreinamentoParticipante[]

  @@index([tipo])
  @@index([dataInicio])
}

model TreinamentoParticipante {
  id             String      @id @default(cuid())
  treinamentoId  String
  funcionarioId  String
  presente       Boolean     @default(true)
  nota           Float?
  certificadoUrl String?
  dataVencimento DateTime?
  createdAt      DateTime    @default(now())
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  treinamento    Treinamento @relation(fields: [treinamentoId], references: [id], onDelete: Cascade)

  @@unique([treinamentoId, funcionarioId])
  @@index([funcionarioId])
  @@index([dataVencimento])
}

model ConfigEstoque {
  id             String    @id @default(cuid())
  categoriasOmie String[]  @default(["3.1"])
  ultimaSincProd DateTime?
  ultimaSincMov  DateTime?
  updatedAt      DateTime  @updatedAt
  palavrasChave  String[]  @default([])
  locaisOmie     Json?
}

// Revisão da LPC carregada por OP (do SharePoint). O arquivo mantém o nome e
// muda só o sufixo de revisão (T78A-LPC_R00 → R01). Sem FK em OP: obras do
// SharePoint podem não estar cadastradas como OP no portal.
model LpcRevisao {
  opNumero       String   @id
  revisao        Int      @default(0)
  arquivo        String?
  itens          Int      @default(0)
  importadoEm    DateTime @default(now())
  importadoPorId String?

  @@index([revisao])
}

// Caminho salvo da pasta de LPC de cada OP no SharePoint. Definido navegando
// uma vez (evita a busca automática pegar o arquivo/pasta errado).
model OpLpcPasta {
  opPasta    String   @id // nome da pasta da OP ("OP-067 - Danpower …")
  pastaPath  String // caminho relativo do folder onde ficam os LPC
  salvoEm    DateTime @default(now())
  salvoPorId String?
}

// Parâmetros do PCP (chave-valor) — ex.: meta_corte_kg_mes = "250000"
model PcpParametro {
  chave     String   @id
  valor     String
  updatedAt DateTime @updatedAt
}

model EstoqueItem {
  id               String                @id @default(cuid())
  codigoOmie       String                @unique
  codigoIntegracao String?               @unique
  descricao        String
  categoriaOmie    String
  categoriaLabel   String?
  unidade          String
  cmc              Float                 @default(0)
  qtdAtual         Float                 @default(0)
  ativo            Boolean               @default(true)
  ultimaSincOmie   DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  estoqueTorg      Boolean               @default(false)
  locaisQtd        Json?
  movimentacoes    EstoqueMovimentacao[]
  reservas         EstoqueReserva[]

  @@index([categoriaOmie])
  @@index([estoqueTorg])
  @@index([ativo])
  @@index([estoqueTorg, ativo])
  @@index([descricao])
}

model EstoqueReserva {
  id            String      @id @default(cuid())
  itemEstoqueId String
  opId          String
  rmItemId      String?
  qtdReservada  Float
  qtdConsumida  Float       @default(0)
  status        String      @default("ATIVA")
  cancelMotivo  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  itemEstoque   EstoqueItem @relation(fields: [itemEstoqueId], references: [id], onDelete: Cascade)
  op            OP          @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@index([opId])
  @@index([itemEstoqueId, status])
}

model EstoqueMovimentacao {
  id             String            @id @default(cuid())
  itemEstoqueId  String
  tipo           String
  origem         String
  quantidade     Float
  cmcMomento     Float?
  observacao     String?
  syncCodigoOmie String?           @unique
  createdAt      DateTime          @default(now())
  createdById    String?
  alocacoes      EstoqueAlocacao[]
  itemEstoque    EstoqueItem       @relation(fields: [itemEstoqueId], references: [id], onDelete: Cascade)

  @@index([itemEstoqueId])
  @@index([tipo, createdAt])
}

model EstoqueAlocacao {
  id             String              @id @default(cuid())
  movimentacaoId String
  opId           String
  reservaId      String?
  quantidade     Float
  valorCMC       Float
  ajustadoManual Boolean             @default(false)
  ajustadoById   String?
  createdAt      DateTime            @default(now())
  movimentacao   EstoqueMovimentacao @relation(fields: [movimentacaoId], references: [id], onDelete: Cascade)
  op             OP                  @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@index([opId])
  @@index([movimentacaoId])
}

model EstoqueFisico {
  id          String    @id @default(cuid())
  perfil      String
  bitola      String
  qtd         Int       @default(1)
  comprimento Float?
  largura     Float?
  area        Float?
  peso        Float     @default(0)
  origem      String?
  destino     String?
  obra        String?
  aco         String?
  dataLanc    DateTime?
  inspCorr    String?
  opReserva   String?
  sheet       String
  createdAt   DateTime  @default(now())

  @@index([perfil])
