// Schema do Portal de Compras Torg Metal
// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USUÁRIOS / AUTENTICAÇÃO ────────────────────────────────

enum TipoUsuario {
  ADMIN    // acesso total ao sistema; não tem módulos específicos
  USUARIO  // acesso restrito aos módulos liberados em UserModulo
}

enum Modulo {
  COMERCIAL
  ENGENHARIA
  COMPRAS
  PRODUCAO
  ALMOXARIFADO
  FINANCEIRO
  EXPEDICAO
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String
  password  String      // bcrypt hash
  tipo      TipoUsuario
  setor     String?
  ativo     Boolean     @default(true)
  // Permite alterar verba direto, sem passar pelo fluxo de solicitacao
  // pendente de aprovacao do master. Usado pra usuarios COMERCIAL de
  // confianca que precisam ajustar valores frequentemente.
  podeAlterarVerba Boolean @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  modulos                 UserModulo[]
  opsCriadas              OP[]                @relation("OPCreatedBy")
  rmsCriadas              RM[]                @relation("RMCreatedBy")
  aditivos                Aditivo[]
  revisoesCriadas         Revisao[]           @relation("RevisaoCreatedBy")
  ajustesPrazoCriados     AjustePrazo[]       @relation("AjustePrazoCreatedBy")
  solicitacoesCriadas     SolicitacaoVerba[]  @relation("SolicitacaoCreatedBy")
  solicitacoesDecididas   SolicitacaoVerba[]  @relation("SolicitacaoDecididoBy")
  auditLogs               AuditLog[]
  notificacoes            Notificacao[]
  sharepointSyncs         SharepointSync[]
  producaoDiarias         ProducaoDiaria[]     @relation("ProducaoDiariaCreatedBy")
  passwordResetTokens     PasswordResetToken[]
  orcamentosCriados       Orcamento[]          @relation("OrcamentoCriadoPor")
  estudosCriados          PropostaEstudo[]     @relation("EstudoCriadoPor")
  recebimentos            Recebimento[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique        // código de 6 dígitos
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime                // expira em 15 minutos
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── METAS / OBJETIVOS ─────────────────────────────────────
// Metas mensais por módulo/setor com distribuição semanal.
// Admin define o valor mensal; distribuição semanal é automática (÷ 4 semanas)
// ou manual quando os campos semana1-5 são preenchidos.

model Meta {
  id          String   @id @default(cuid())
  modulo      String   // PRODUCAO, COMERCIAL, FINANCEIRO, EXPEDICAO, COMPRAS
  tipo        String   // PESO_KG, FATURAMENTO_BRL, QTD_PEDIDOS, etc.
  setor       String   @default("GERAL") // CORTE, MONTAGEM, etc. ou GERAL
  ano         Int
  mes         Int      // 1-12
  valorMensal Float    @default(0) // valor total do mês (kg pra peso, R$ pra financeiro)
  // Distribuição semanal (null = auto ÷ 4 semanas).
  // Quando preenchido, sobrescreve a distribuição automática.
  semana1     Float?
  semana2     Float?
  semana3     Float?
  semana4     Float?
  semana5     Float?   // apenas meses com 5 semanas úteis

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([modulo, tipo, setor, ano, mes])
  @@index([modulo, ano])
  @@index([modulo, tipo, ano])
}

model UserModulo {
  id     String @id @default(cuid())
  userId String
  modulo Modulo

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modulo])
  @@index([userId])
}

// ─── OP (ORDEM DE PRODUÇÃO) ─────────────────────────────────

enum OPStatus {
  ABERTA
  EM_EXECUCAO
  ENCERRADA
  ATRASADA
  CANCELADA
}

model OP {
  id          String   @id @default(cuid())
  numero      String   @unique // T083, T084, etc
  cliente     String
  obra        String?
  descricao   String?
  status      OPStatus @default(ABERTA)

  // Cronograma
  dataInicio       DateTime?
  dataFimPrevista  DateTime?
  dataFimReal      DateTime?

  // Dados fiscais do cliente (necessario quando OP tem itens em
  // Faturamento Direto — Omie precisa emitir nota direto pro cliente)
  clienteRazaoSocial String?
  clienteCnpj        String?
  clienteIE          String?  // Inscricao Estadual
  clienteEndereco    String?
  clienteCidade      String?
  clienteUF          String?
  clienteCep         String?
  clienteContato     String?
  clienteEmail       String?
  clienteTelefone    String?

  // Valor total do contrato com o cliente. Inclui TUDO (receita Torg +
  // materiais em Faturamento Direto que serao faturados em nome do cliente).
  // Quando preenchido, vira a fonte de verdade pra calcular margem — sem
  // ele, o sistema fallback pra soma de receitas (que so reflete o que Torg
  // fatura, ignora os FDs).
  valorTotalContrato Float?

  createdById String
  createdBy   User     @relation("OPCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itens          OPItem[]
  aditivos       Aditivo[]
  revisoes       Revisao[]
  ajustesPrazo   AjustePrazo[]
  rms            RM[]
  receitas       OPReceita[]
  medicoes       OPMedicao[]
  producaoSemanal ProducaoSemanal[]
  fluxoCaixa     FluxoCaixa[]
  romaneios      Romaneio[]
  planejamentosCarga PlanejamentoCarga[]
  estoqueReservas EstoqueReserva[]
  estoqueAlocacoes EstoqueAlocacao[]
  rmItensDestino  RMItem[]   @relation("RMItemOpDestino")
  pedidosOmieAvulsos PedidoOmie[]   // pedidos cadastrados direto na OP (FD avulsos)
  pecasConjunto   PecaConjunto[]
  orcamentos      Orcamento[]    @relation("OrcamentoOP")
  mesApontamentos MesApontamento[] @relation("MesApontamentosOP")

  @@index([numero])
  @@index([status])
  @@index([status, createdAt])   // listagem de OPs por status ordenada por data
  @@index([createdById, status]) // OPs criadas por usuário + filtro de status
}

// ─── PRODUÇÃO (PCP / FÁBRICA) ─────────────────────────────────
// Pesos previstos x realizados de estruturas, por semana e por OP.
// Inputado manualmente pelo time de PCP/Produção (ou via import xlsx).

model ProducaoSemanal {
  id              String   @id @default(cuid())

  // DIA especifico — chave principal
  data            DateTime
  // Cache: semana ISO (ex: "2026-W19") + range pra agrupamento
  semana          String
  dataInicio      DateTime // segunda da semana
  dataFim         DateTime // sabado da semana

  // Producao em estrutura (kg)
  pesoPrevistoKg  Float    @default(0)
  pesoRealizadoKg Float    @default(0)

  // Valor associado (R$, opcional — pra fluxo financeiro)
  valorPrevisto   Float    @default(0)
  valorRealizado  Float    @default(0)

  // Quebrado por OP (opcional — null = total geral do dia)
  opId            String?
  op              OP?      @relation(fields: [opId], references: [id], onDelete: SetNull)

  observacao      String?

  // Fonte da informacao: MANUAL (usuario lancou), IMPORT (planilha local), SHAREPOINT (sync auto).
  fonte           String?

  // Setor da fabrica (Corte, Montagem, Solda, Acabamento, Jato, Pintura, Expedicao).
  // null = lancamento geral/agregado (lancamentos manuais antigos).
  setor           String?

  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([data, opId, setor])
  @@index([data])
  @@index([semana])
  @@index([opId])
  @@index([setor])
}

// Romaneio = nota de expedicao com peso REAL produzido/expedido.
// Usado pra validar peso previsto vs realizado e calcular receita gerada.
model Romaneio {
  id          String   @id @default(cuid())
  numero      String   // numero do romaneio (ex: "R-001/2026")

  opId        String?
  op          OP?      @relation(fields: [opId], references: [id], onDelete: SetNull)

  data        DateTime // data de emissao/expedicao
  pesoRealKg  Float    // peso real produzido/expedido (kg)

  descricao   String?  // descricao do que foi produzido
  observacao  String?

  // Snapshot do valor unitario (R$/kg) usado pra calcular receita gerada
  valorPorKg  Float?
  valorTotal  Float?   // pesoRealKg * valorPorKg (calculado e armazenado)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itens       RomaneioItem[]
  planejamentoCarga PlanejamentoCarga?

  @@index([opId])
  @@index([data])
}

// Itens detalhados de um romaneio — vincula peças (PecaConjunto) e
// acessórios (RMItem) ao romaneio de saída. Permite rastrear QUAIS
// itens foram expedidos em cada carga.
model RomaneioItem {
  id              String        @id @default(cuid())
  romaneioId      String
  romaneio        Romaneio      @relation(fields: [romaneioId], references: [id], onDelete: Cascade)

  // Tipo do item: PECA (estrutura/marca) ou ACESSORIO (item de RM expedível)
  tipo            String        // PECA | ACESSORIO
  descricao       String        // descrição (ex: "T64K1 - VIGA" ou "Parafusos M16")

  // Vínculo com peça de estrutura (marca da LE/form21)
  pecaConjuntoId  String?
  pecaConjunto    PecaConjunto? @relation(fields: [pecaConjuntoId], references: [id])

  // Vínculo com item de RM (acessórios expedíveis)
  rmItemId        String?
  rmItem          RMItem?       @relation(fields: [rmItemId], references: [id])

  qtd             Float         @default(1)   // quantidade expedida neste romaneio
  pesoKg          Float?        // peso deste item (kg)
  observacao      String?

  createdAt       DateTime      @default(now())

  @@index([romaneioId])
  @@index([pecaConjuntoId])
  @@index([rmItemId])
}

// ─── PLANEJAMENTO DE CARGA ─────────────────────────────────
// Lista o que DEVERIA ser carregado numa carga (antes do romaneio).
// Quando a carga acontece, gera um Romaneio. Itens que não foram
// carregados recebem motivo e podem ser reprogramados pra próxima carga.

model PlanejamentoCarga {
  id           String   @id @default(cuid())
  opId         String
  op           OP       @relation(fields: [opId], references: [id])

  dataPrevista DateTime               // data prevista de carregamento
  descricao    String?                // ex: "Carga 1 - Mezanino etapa 1"
  // PLANEJADO: carga planejada, aguardando dia de carregar
  // EM_CARGA: caminhão chegou, carregamento em andamento
  // CONCLUIDO: romaneio gerado, carga saiu
  // CANCELADO: carga cancelada
  status       String   @default("PLANEJADO")

  // Quando concluído, vincula ao romaneio oficial
  romaneioId   String?  @unique
  romaneio     Romaneio? @relation(fields: [romaneioId], references: [id])

  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  itens        PlanejamentoCargaItem[]

  @@index([opId])
  @@index([status])
  @@index([dataPrevista])
}

// Item do planejamento de carga. Pode ser peça (PecaConjunto) ou
// acessório (RMItem expedível). Acompanha se foi carregado ou não.
model PlanejamentoCargaItem {
  id                  String              @id @default(cuid())
  planejamentoId      String
  planejamento        PlanejamentoCarga   @relation(fields: [planejamentoId], references: [id], onDelete: Cascade)

  tipo                String              // PECA | ACESSORIO
  descricao           String

  pecaConjuntoId      String?
  pecaConjunto        PecaConjunto?       @relation(fields: [pecaConjuntoId], references: [id])
  rmItemId            String?
  rmItem              RMItem?             @relation(fields: [rmItemId], references: [id])

  qtdPlanejada        Float               @default(1)
  qtdCarregada        Float               @default(0)   // preenchido ao gerar romaneio
  pesoEstimadoKg      Float?              // peso estimado do item

  // PLANEJADO: item aguardando carregamento
  // CARREGADO: item foi no romaneio (qtdCarregada = qtdPlanejada)
  // PARCIAL: carregou menos que o planejado
  // NAO_ENVIADO: não foi carregado (precisa de motivo)
  // REPROGRAMADO: reagendado pra próxima carga
  status              String              @default("PLANEJADO")
  motivoNaoEnvio      String?             // obrigatório quando NAO_ENVIADO
  // Referência ao planejamento futuro onde esse item foi reprogramado
  reprogramadoParaId  String?

  createdAt           DateTime            @default(now())

  @@index([planejamentoId])
  @@index([pecaConjuntoId])
  @@index([rmItemId])
  @@index([status])
}

// Fluxo de caixa previsto (entradas e saidas)
model FluxoCaixa {
  id            String   @id @default(cuid())

  data          DateTime // data prevista de entrada/saida
  tipo          String   // 'ENTRADA' | 'SAIDA'
  categoria     String   // FATURAMENTO_MEDICAO | RECEBIMENTO | SALARIO | IMPOSTO | COMPRA | TRIBUTO | OUTROS
  descricao     String
  valor         Float    // sempre positivo (tipo define se entra ou sai)

  // Realizado: quando entrou/saiu efetivo
  realizado     Boolean  @default(false)
  dataRealizado DateTime?

  // Vinculo opcional com OP
  opId          String?
  op            OP?      @relation(fields: [opId], references: [id], onDelete: SetNull)

  observacao    String?

  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([data])
  @@index([tipo])
  @@index([categoria])
  @@index([opId])
}

// ─── MEDIÇÕES (Pedidos de Venda do Omie vinculados à OP) ──────
// Cada medição = 1 Pedido de Venda no Omie, com vários produtos.
// Aqui guardamos só o snapshot dos dados pra mostrar no portal.

model OPMedicao {
  id          String   @id @default(cuid())
  opId        String
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  // Tipo de documento Omie: "VENDA" (Pedido de Venda — default histórico)
  // ou "SERVICO" (Ordem de Servico). Define qual API consultar.
  tipoDocumento    String   @default("VENDA")
  // Identificadores no Omie
  numeroPedidoOmie String  // Numero visivel (ex: "1500" ou "233/1" pra OS)
  codigoPedidoOmie String? // codigo_pedido / codigo_os interno do Omie

  // Snapshot dos dados (sincronizado via API Omie)
  descricao        String?
  data             DateTime?
  // valorBruto = quanto JA FOI MEDIDO/FATURADO desse pedido (default: parcelas
  // com nFatura ou etapa=60 = total). Pode ser editado manualmente quando a
  // detecccao automatica nao bate.
  valorBruto       Float    @default(0)
  valorLiquido     Float?
  // valorContratado = valor_total_pedido do Omie (info auxiliar pra
  // comparar quanto foi medido vs contratado)
  valorContratado  Float?
  // valorFaturado bruto detectado das parcelas (mesma logica do valorBruto,
  // guardado pra auditoria — pode divergir se usuario editou manualmente)
  valorFaturadoAuto Float?
  status           String?  // ABERTO | FATURADO | CANCELADO | etc
  etapa            String?  // codigo da etapa do pedido no Omie
  qtdItens         Int      @default(0)

  // Sincronizacao
  ultimoSync       DateTime?
  syncErro         String?
  payload          Json?    // Resposta do Omie (auditoria)

  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([opId])
  @@unique([opId, numeroPedidoOmie])
}

// ─── RECEITAS DA OP ──────────────────────────────────────────
// Linhas de receita do contrato (projeto, montagem, fabricacao, etc.)
// com aliquotas de impostos por linha pra controle financeiro.

model OPReceita {
  id          String   @id @default(cuid())
  opId        String
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  ordem       Int      @default(0)
  categoria   String   // PROJETO | MONTAGEM | FABRICACAO | MATERIAL | OUTRO
  descricao   String
  cfop        String?  // codigo CFOP (ex: "5101", "5933", "6101")
  codigoServico String? // codigo de servico ISS quando aplicavel

  valor       Float    // valor bruto da receita

  // Aliquotas tributarias em % (cada linha pode ter regime/CFOP diferente)
  icmsPct     Float?
  ipiPct      Float?
  pisPct      Float?
  cofinsPct   Float?
  issPct      Float?
  irrfPct     Float?
  csllPct     Float?

  observacao  String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([opId])
  @@index([categoria])
}

enum ItemTipo {
  VERBA       // só R$ — parafusos, tinta, galvanização
  ESTRUTURA   // peso (KG/TON) + verba
  AREA        // m² — telhas, steel deck, placa wall
  ALUGUEL     // meses × valor/mês + descrição da capacidade
  GENERICO    // qtd + unidade livre + verba
}

model OPItem {
  id              String  @id @default(cuid())
  opId            String
  op              OP      @relation(fields: [opId], references: [id], onDelete: Cascade)

  ordem           Int     @default(0)
  categoria       String  // "MATERIA_PRIMA", "TINTA", "ALUGUEL_PLATAFORMA", "OUTRO", etc
  tipo            ItemTipo @default(VERBA)
  descricao       String
  codigoOmie      String?

  // Local: FABRICA ou TERCEIRO
  localEstoque    String?

  // Para ESTRUTURA / AREA / GENERICO
  unidade         String?
  qtdContratada   Float?
  cmcMedio        Float?   // R$/unidade (R$/kg, R$/m²) — opcional

  // Para ALUGUEL
  meses           Int?
  valorPorMes     Float?
  capacidade      String?  // texto livre da capacidade do equipamento

  valorVerba      Float    // sempre tem; calculado auto p/ ESTRUTURA/AREA (qtd*cmc) e ALUGUEL (meses*valorMes)
  faturamentoDireto Boolean @default(false)
  observacao      String?

  rmItens             RMItem[]
  solicitacoesVerba   SolicitacaoVerba[]

  @@index([opId])
  @@index([categoria])
}

// Revisão: registro de mudanças na OP base (cliente, descrição, qtd dos itens base, etc)
// Comercial cria a revisão com motivo; alterações são aplicadas direto na OP/OPItem
model Revisao {
  id          String   @id @default(cuid())
  opId        String
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)
  numero      Int      // Rev 1, 2, 3...
  motivo      String

  createdById String
  createdBy   User     @relation("RevisaoCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([opId, numero])
  @@index([opId])
}

// Aditivo: acréscimo ao contrato — TEM SUAS PRÓPRIAS LINHAS DE ITENS (AditivoItem)
model Aditivo {
  id          String   @id @default(cuid())
  opId        String
  op          OP       @relation(fields: [opId], references: [id], onDelete: Cascade)
  numero      Int      // Aditivo 1, 2, 3...
  descricao   String   // razão / breve descrição

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  itens       AditivoItem[]

  @@unique([opId, numero])
  @@index([opId])
}

model AditivoItem {
  id              String  @id @default(cuid())
  aditivoId       String
  aditivo         Aditivo @relation(fields: [aditivoId], references: [id], onDelete: Cascade)

  ordem           Int     @default(0)
  categoria       String
  tipo            ItemTipo @default(VERBA)
  descricao       String
  codigoOmie      String?

  localEstoque    String?

  unidade         String?
  qtdContratada   Float?
  cmcMedio        Float?

  meses           Int?
  valorPorMes     Float?
  capacidade      String?

  valorVerba      Float
  faturamentoDireto Boolean @default(false)
  observacao      String?

  rmItens             RMItem[]
  solicitacoesVerba   SolicitacaoVerba[]

  @@index([aditivoId])
  @@index([categoria])
}

// Ajuste de Prazo: extensão da data fim prevista da OP. Apenas usuário master.
model AjustePrazo {
  id              String   @id @default(cuid())
  opId            String
  op              OP       @relation(fields: [opId], references: [id], onDelete: Cascade)

  dataFimAnterior DateTime
  dataFimNova     DateTime
  motivo          String

  createdById     String
  createdBy       User     @relation("AjustePrazoCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  @@index([opId])
}

// Solicitação de mudança de verba — comercial pede, master aprova/rejeita por item
enum SolicitacaoVerbaStatus {
  PENDENTE
  APROVADA
  REJEITADA
}

model SolicitacaoVerba {
  id              String   @id @default(cuid())

  // Item afetado: pode ser de OP ou de Aditivo
  opItemId        String?
  opItem          OPItem?  @relation(fields: [opItemId], references: [id], onDelete: Cascade)
  aditivoItemId   String?
  aditivoItem     AditivoItem? @relation(fields: [aditivoItemId], references: [id], onDelete: Cascade)

  valorAtual      Float
  valorProposto   Float
  justificativa   String

  status          SolicitacaoVerbaStatus @default(PENDENTE)
  observacaoMaster String?
  decididoEm      DateTime?
  decididoById    String?
  decididoBy      User?    @relation("SolicitacaoDecididoBy", fields: [decididoById], references: [id])

  createdById     String
  createdBy       User     @relation("SolicitacaoCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  @@index([opItemId])
  @@index([aditivoItemId])
  @@index([status])
}

// ─── RM (REQUISIÇÃO DE MATERIAL) ────────────────────────────

enum RMStatus {
  ABERTA
  EM_COTACAO
  COTADA
  PEDIDO_GERADO
  CANCELADA
}

enum TipoRM {
  ENGENHARIA      // vinculada a OP + categorias (tipo de material) do escopo do comercial
  INTERNA         // sem vinculo a OP — almoxarifado, coisas internas, etc
}

model RM {
  id          String   @id @default(cuid())
  numero      String   @unique // RM-0001
  tipoRM      TipoRM   @default(ENGENHARIA)
  opId        String?
  op          OP?      @relation(fields: [opId], references: [id])
  // categorias da OP cobertas por essa RM (so pra ENGENHARIA)
  categoriasOP String[] @default([])
  tipo        String   @default("Material") // Material, Consumível
  descricao   String
  observacao  String?
  status      RMStatus @default(ABERTA)

  // Configuração para pedido Omie (escolhida na RM)
  categoriaCompra String?
  localEstoque    String?

  // Solicitante
  createdById String
  createdBy   User     @relation("RMCreatedBy", fields: [createdById], references: [id])
  setor       String?  // setor capturado no momento da criação (snapshot)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itens       RMItem[]
  cotacoes    Cotacao[]
  envios      Envio[]
  anexos      Anexo[]
  pedidosFDAtendidos PedidoOmie[] @relation("PedidoOmieRMAtendida")

  @@index([opId])
  @@index([status])
  @@index([createdById])
  @@index([status, createdAt])   // listagem de RMs por status ordenada por data
  @@index([opId, status])        // RMs de uma OP filtradas por status
}

enum RMItemStatus {
  PENDENTE        // ainda nao cotado
  EM_COTACAO      // enviado pra fornecedor
  COTADO          // recebeu proposta, aguarda escolha
  PEDIDO_GERADO   // virou pedido de compra
  CANCELADO       // decisao de nao comprar (com motivo)
}

// Pedido de compra gerado no Omie. Cada pedido representa 1 fornecedor
// vencedor de N itens da OP (agrupamento de RMItens por cotacao).
model PedidoOmie {
  id                String   @id @default(cuid())
  cotacaoId         String?
  cotacao           Cotacao? @relation(fields: [cotacaoId], references: [id])

  fornecedorNome    String
  nCodFor           String?  // codigo do fornecedor no Omie
  cnpj              String?

  codigoPedido      String?  // codigo_pedido retornado pelo Omie
  numeroPedido      String?  // numero_pedido (mais legivel)
  total             Float    @default(0)
  faturamentoDireto Boolean  @default(false)
  status            String   @default("CRIADO")  // CRIADO | ERRO

  observacao        String?
  erroOmie          String?
  payload           Json?    // payload enviado (auditoria)
  resposta          Json?    // resposta do Omie

  // Vinculo direto pra OP — usado em FD avulsos (cadastros manuais
  // sem RM/Cotacao prévia, pra regularizar compras que ocorreram fora
  // do fluxo do portal).
  opId              String?
  op                OP?      @relation(fields: [opId], references: [id])

  // Pedido cadastrado manualmente (fora do fluxo RM → Cotacao → Pedido).
  // Quando true, geralmente significa regularizacao de FD existente.
  criadoManualmente Boolean  @default(false)
  // PDF anexo da NF/pedido (URL Vercel Blob) — pra cadastros manuais
  anexoUrl          String?
  anexoNome         String?
  // Categoria do material/escopo (ex: STEEL_DECK, TINTA, PARAFUSOS) — pra
  // cadastros manuais; quando via cotacao a categoria sai pelos rmItens.
  categoriaItem     String?
  // Itens detalhados do FD avulso (cadastros manuais). Array de objetos
  // { descricao, qtd, unidade, valorUnit, ipiPct, icmsPct, codigo? }.
  // Quando vazio, o "Criar no Omie" usa 1 item generico com o total embutido.
  itensDetalhes     Json?
  // RM que esse FD avulso atende. Quando preenchido, ao salvar marca
  // todos os RMItens dela como PEDIDO_GERADO e a RM tambem — saindo
  // da lista de RMs ativas do Compras.
  rmAtendidaId      String?
  rmAtendida        RM?      @relation("PedidoOmieRMAtendida", fields: [rmAtendidaId], references: [id])

  createdById       String?
  createdAt         DateTime @default(now())

  // Rastreamento de entrega — preenchido a partir do prazo do fornecedor vencedor
  prazoEntregaPrevisto DateTime? // data mais tarde entre prazos dos itens vencedores
  dataEntregaReal      DateTime? // quando de fato chegou
  statusEntrega        String?   // NO_PRAZO | PROXIMO | ATRASADO | ENTREGUE

  rmItens           RMItem[]
  recebimentos      Recebimento[]

  @@index([cotacaoId])
  @@index([opId])
  @@index([status])
}

model RMItem {
  id          String  @id @default(cuid())
  rmId        String
  rm          RM      @relation(fields: [rmId], references: [id], onDelete: Cascade)

  // OP destinataria deste item (multi-OP via RM). Pode ser null quando
  // a linha eh compra pra estoque livre (sem destino especifico).
  opDestinoId   String?
  opDestino     OP?     @relation("RMItemOpDestino", fields: [opDestinoId], references: [id])
  // Quando true, este item vai pro estoque e e consumido depois via CMC.
  // Quando false, comportamento atual (sob encomenda / FD direto pra OP).
  destinoEstoque Boolean @default(false)
  // Codigo do item no Omie (cCodProduto) — quando o usuario souber,
  // permite vincular direto ao EstoqueItem. Sem isso, vira "compra avulsa"
  // sem reserva automatica.
  codigoOmieEstoque String?

  // Vinculo com item da OP base OU com item de Aditivo (exatamente um dos dois)
  opItemId      String?
  opItem        OPItem?      @relation(fields: [opItemId], references: [id])
  aditivoItemId String?
  aditivoItem   AditivoItem? @relation(fields: [aditivoItemId], references: [id])

  ordem       Int     @default(0)
  descricao   String
  unidade     String
  qtd         Float
  status      RMItemStatus @default(PENDENTE)
  canceladoMotivo String?
  canceladoEm     DateTime?

  // Quando o item vira pedido, vincula o pedido Omie aqui
  pedidoOmieId String?
  pedidoOmie   PedidoOmie? @relation(fields: [pedidoOmieId], references: [id])

  // Detalhe (do Tekla quando importado)
  material    String?
  comprimento String?
  largura     String?
  peso        Float?
  pesoLinear  Float?
  codigo      String?
  tratamento  String?

  cotacaoItens    CotacaoItem[]
  romaneioItens   RomaneioItem[]
  planejamentoCargaItens PlanejamentoCargaItem[]
  recebimentos    Recebimento[]

  @@index([rmId])
  @@index([opItemId])
  @@index([aditivoItemId])
  @@index([status])
  @@index([pedidoOmieId])
  @@index([status, opDestinoId]) // itens pendentes por OP de destino
  @@index([rmId, status])        // itens de uma RM filtrados por status
}

// ─── COTAÇÕES ───────────────────────────────────────────────

enum CotacaoStatus {
  PENDENTE      // aguardando fornecedor responder
  RECEBIDA      // fornecedor respondeu
  VENCIDA       // passou do prazo
  CANCELADA
}

model Cotacao {
  id              String        @id @default(cuid())
  rmId            String
  rm              RM            @relation(fields: [rmId], references: [id], onDelete: Cascade)

  // Fornecedor — vinculo ao cadastro unificado. Campos denormalizados mantidos pra auditoria.
  fornecedorId    String?
  fornecedor      Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  fornecedorNome  String
  fornecedorEmail String?
  nCodOmie        String?       // codigo do fornecedor no Omie
  cnpj            String?

  faturamento     String        @default("Torg") // Torg | Cliente
  prazoPagamento  String?
  observacao      String?
  total           Float         @default(0)
  // Total declarado pelo fornecedor (do PDF da proposta). Quando setado, vira
  // a "fonte da verdade" do valor da NF — usado pra ajustar precos no Omie
  // proporcionalmente, garantindo que o pedido bata com a proposta.
  totalProposta   Float?

  prazoResposta   DateTime?     // limite pra fornecedor responder
  recebidaEm      DateTime?
  // Marca quando Compras pediu "revisao final" — o fornecedor entra no portal
  // e ve so os itens em que ele venceu (vencedor=true) pra confirmar os
  // valores finais antes da geracao do pedido. Quando setado, o portal
  // entra em modo "revisao final" com aviso destacado.
  solicitadaRevisaoFinal DateTime?
  status          CotacaoStatus @default(PENDENTE)

  // Token único para acesso do fornecedor (uploads via /fornecedores/c/[token])
  token           String?       @unique
  numeroRevisao   Int           @default(0) // incrementa a cada re-submissao do fornecedor

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  itens           CotacaoItem[]
  anexos          Anexo[]
  pedidosOmie     PedidoOmie[]

  @@index([rmId])
  @@index([fornecedorId])
  @@index([status])
  @@index([token])
  @@index([status, createdAt])   // cotações por status ordenadas por data
  @@index([rmId, status])        // cotações de uma RM filtradas por status
}

model CotacaoItem {
  id          String  @id @default(cuid())
  cotacaoId   String
  cotacao     Cotacao @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rmItemId    String
  rmItem      RMItem  @relation(fields: [rmItemId], references: [id])

  precoUnit      Float
  qtdCotada      Float
  qtdProposta    Float?
  icmsPct        Float?
  ipiPct         Float?
  observacao     String?
  vencedor       Boolean   @default(false) // marcado quando o compras escolhe
  prazoEntrega   DateTime? // data prevista de entrega informada pelo fornecedor

  @@index([cotacaoId])
  @@index([rmItemId])
  @@index([cotacaoId, vencedor]) // itens vencedores de uma cotação
  @@index([rmItemId, vencedor])  // item de RM que foi vencedor
}

// Histórico de e-mails enviados aos fornecedores
model Envio {
  id              String   @id @default(cuid())
  rmId            String
  rm              RM       @relation(fields: [rmId], references: [id], onDelete: Cascade)
  fornecedorNome  String
  fornecedorEmail String
  data            DateTime @default(now())
  status          String   @default("Enviado")

  @@index([rmId])
}

// ─── ANEXOS (Vercel Blob) ───────────────────────────────────

model Anexo {
  id          String   @id @default(cuid())

  // Polimórfico — pode estar vinculado a RM ou Cotacao
  cotacaoId   String?
  cotacao     Cotacao? @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  rmId        String?
  rm          RM?      @relation(fields: [rmId], references: [id], onDelete: Cascade)

  nomeArquivo String
  blobUrl     String   // URL do Vercel Blob
  tamanho     Int      // bytes
  tipo        String   // pdf, image/png, etc
  uploadedAt  DateTime @default(now())

  @@index([cotacaoId])
  @@index([rmId])
}

// ─── AUDITORIA ──────────────────────────────────────────────

// Log de todas as ações pra rastreabilidade
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // create_op, update_op_item, delete_rm, etc
  entity    String   // OP, RM, Cotacao, OPItem, etc
  entityId  String
  diff      Json?    // {before, after} se aplicável
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── FORNECEDORES (Vendor List) ─────────────────────────────

// Cadastro de fornecedores classificados por categoria de material/servico.
// Usado pra selecionar destinatarios no envio de cotacao (em vez de digitar
// nome/email manualmente toda vez).
model Fornecedor {
  id              String   @id @default(cuid())
  razaoSocial     String
  nomeFantasia    String?
  cnpj            String?
  email           String   // email principal
  emailsAdicionais String[] // emails secundarios (copias)
  telefone        String?
  contato         String?  // nome do vendedor/contato
  cidade          String?
  uf              String?

  // Categorias que esse fornecedor atende. Codigos do catalogo
  // lib/fornecedor-categorias.js (MATERIA_PRIMA, TINTA, etc).
  categorias      String[]
  observacao      String?

  // Integracao Omie — pra resolver pedido sem precisar buscar de novo
  nCodOmie        String?

  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cotacoes        Cotacao[]

  @@index([ativo])
}

// ─── NOTIFICACOES POR EMAIL ─────────────────────────────────

// Lista de emails inscritos em eventos do sistema (RM criada, etc).
// Mantida pelo admin via /admin/notificacoes. Toda criacao de RM
// dispara email pros emails inscritos no evento RM_CRIADA.
model EmailNotificacao {
  id        String   @id @default(cuid())
  email     String
  nome      String?  // nome de exibicao pro tooltip
  // Eventos que esse email recebe. Strings livres pra futura extensao.
  // Hoje suportados: "RM_CRIADA", "COTACAO_RESPONDIDA"
  eventos   String[]
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
}

// ─── CATEGORIAS CUSTOMIZADAS DE FORNECEDORES ────────────────
// Alem das 7 categorias built-in (MATERIA_PRIMA, TINTA, etc — em
// lib/fornecedor-categorias.js), admin/compras pode cadastrar mais
// categorias aqui pelo botao "Gerenciar categorias" do Vendor List.
model CategoriaFornecedor {
  id        String   @id @default(cuid())
  codigo    String   @unique // ex: "PINTURA_AUTOMOTIVA" (auto-gerado do label)
  label     String   // ex: "Pintura Automotiva"
  color     String   @default("slate") // blue|purple|slate|amber|red|emerald|orange
  ordem     Int      @default(100)
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── FEED DE ATIVIDADES (NOTIFICACOES IN-APP) ──────────────
// Registra eventos do sistema (RM criada, cotacao respondida) pra exibir
// em /compras/notificacoes como feed cronologico. Independente do envio
// por email (que e best-effort via Resend).
enum NotificacaoTipo {
  RM_CRIADA
  COTACAO_RESPONDIDA
}

model Notificacao {
  id        String          @id @default(cuid())
  tipo      NotificacaoTipo
  titulo    String          // ex: "Nova RM 0042 criada por João"
  mensagem  String          // texto descritivo
  link      String?         // url interna pra abrir o item (RM, cotacao)
  // Dados estruturados pra exibicao rica (numeros, fornecedor, total, etc)
  dados     Json?
  // Quem disparou o evento (opcional). Null pra eventos de fornecedor externo.
  origemUserId String?
  origemUser   User? @relation(fields: [origemUserId], references: [id])
  // Marcacao de lida — global, todos veem o mesmo estado pra simplicidade
  // (depois pode evoluir pra UserNotificacao se quiser por-usuario)
  lida      Boolean         @default(false)
  lidaEm    DateTime?
  createdAt DateTime        @default(now())

  @@index([lida])
  @@index([createdAt])
  @@index([tipo])
}

// ─── ESTOQUE TORG ──────────────────────────────────────────

// Configuracao de quais categorias do Omie entram no controle de estoque.
// Singleton (so 1 registro). Default: categoria "3.1".
model ConfigEstoque {
  id              String   @id @default(cuid())
  categoriasOmie  String[] @default(["3.1"])
  // Palavras-chave que identificam um produto como "Estoque Torg" (matéria-prima
  // central). Match case-insensitive na descricao. Ex: ["AÇO", "CHAPA", "TUBO"]
  // Usado quando o Omie nao tem familias estruturadas pra classificar via codigo.
  palavrasChave   String[] @default([])
  ultimaSincProd  DateTime?
  ultimaSincMov   DateTime?
  updatedAt       DateTime @updatedAt
}

// Item do estoque — espelha produto do Omie via ListarPosEstoque.
// Sincronizado periodicamente. CMC e quantidade vem do Omie.
model EstoqueItem {
  id              String   @id @default(cuid())
  codigoOmie      String   @unique
  codigoIntegracao String? @unique
  descricao       String
  categoriaOmie   String
  categoriaLabel  String?
  // Flag que indica se esse item entra no fluxo "Estoque Torg" (centralizado).
  // Setado durante a sync via match das palavras-chave do ConfigEstoque,
  // ou manualmente pelo usuario via UI.
  estoqueTorg     Boolean  @default(false)
  unidade         String
  cmc             Float    @default(0)
  qtdAtual        Float    @default(0)
  ativo           Boolean  @default(true)
  ultimaSincOmie  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservas        EstoqueReserva[]
  movimentacoes   EstoqueMovimentacao[]

  @@index([categoriaOmie])
  @@index([estoqueTorg])
  @@index([ativo])
  @@index([estoqueTorg, ativo])  // listagem principal do estoque Torg ativo
  @@index([descricao])           // busca textual por descrição
}

// Reserva — quanto de cada item foi planejado pra cada OP via linha de RM.
model EstoqueReserva {
  id              String   @id @default(cuid())
  itemEstoqueId   String
  itemEstoque     EstoqueItem @relation(fields: [itemEstoqueId], references: [id], onDelete: Cascade)
  opId            String
  op              OP       @relation(fields: [opId], references: [id], onDelete: Cascade)
  rmItemId        String?
  qtdReservada    Float
  qtdConsumida    Float    @default(0)
  status          String   @default("ATIVA")
  cancelMotivo    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([opId])
  @@index([itemEstoqueId, status])
}

// Movimentacao de estoque — entradas, saidas, ajustes.
model EstoqueMovimentacao {
  id              String   @id @default(cuid())
  itemEstoqueId   String
  itemEstoque     EstoqueItem @relation(fields: [itemEstoqueId], references: [id], onDelete: Cascade)
  tipo            String   // ENTRADA | SAIDA | AJUSTE
  origem          String   // OMIE_NF | OMIE_BAIXA | MANUAL | SYNECO
  quantidade      Float
  cmcMomento      Float?
  observacao      String?
  syncCodigoOmie  String?  @unique
  alocacoes       EstoqueAlocacao[]
  createdAt       DateTime @default(now())
  createdById     String?

  @@index([itemEstoqueId])
  @@index([tipo, createdAt])
}

// Alocacao — quanto de uma SAIDA foi pra cada OP.
model EstoqueAlocacao {
  id              String   @id @default(cuid())
  movimentacaoId  String
  movimentacao    EstoqueMovimentacao @relation(fields: [movimentacaoId], references: [id], onDelete: Cascade)
  opId            String
  op              OP       @relation(fields: [opId], references: [id], onDelete: Cascade)
  reservaId       String?
  quantidade      Float
  valorCMC        Float
  ajustadoManual  Boolean  @default(false)
  ajustadoById    String?
  createdAt       DateTime @default(now())

  @@index([opId])
  @@index([movimentacaoId])
}

// ─── CONTROLE DE PECAS (CONJUNTOS) ─────────────────────────
// Lista de Estrutura (LE / FORM 21) importada por OP. Cada conjunto tem
// marca unica dentro da OP, qte/peso/descricao e status que avanca pelo
// pipeline de producao (pendente -> corte -> ... -> expedido).
model PecaConjunto {
  id            String   @id @default(cuid())
  opId          String?
  op            OP?      @relation(fields: [opId], references: [id], onDelete: SetNull)
  opNumero      String   // backup do numero da OP (caso a OP nao esteja cadastrada)
  item          Int?     // numero do item na LE (1, 2, 3, ...)
  marca         String   // T64K1, T64K2, etc
  descricao     String?  // VIGA, COLUNA, LIGACAO, etc
  qte           Int      @default(1)
  pesoUnitKg    Float    @default(0)
  pesoTotalKg   Float    @default(0)
  precoUnitario Float    @default(0)  // R$ por peça
  precoTotal    Float    @default(0)  // R$ total (precoUnitario * qte)
  // Status atual: PENDENTE | CORTE | MONTAGEM | SOLDA | ACABAMENTO | JATO | PINTURA | EXPEDIDO
  status        String   @default("PENDENTE")
  // Peca sem letra "P" no inicio da marca pula montagem/solda/acab e vai direto pra jato
  fluxoEspecial Boolean  @default(false)
  ultimoSetor   String?  // setor onde foi feito o ultimo apontamento
  dataConcluida DateTime? // quando foi expedida
  dataPrevista  DateTime? // data planejada de conclusao (opcional)
  fonte         String?  // LE_IMPORT | MANUAL
  observacao    String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  planejamentos          PecaPlanejamento[]
  romaneioItens          RomaneioItem[]
  planejamentoCargaItens PlanejamentoCargaItem[]

  @@unique([opNumero, marca])
  @@index([opId])
  @@index([status])
  @@index([marca])
}

// ─── CONTROLE DIÁRIO DE PRODUÇÃO ────────────────────────────
// Preenchido pelo admin: metas e parametros de produção por setor/dia.
model ProducaoDiaria {
  id                      String   @id @default(cuid())
  data                    DateTime @db.Date
  setor                   String   // CORTE, MONTAGEM, SOLDA, ACABAMENTO, JATO, PINTURA, EXPEDICAO
  pesoMetaKg              Float    @default(0)   // meta de peso do dia (kg)
  pesoRealizadoKg         Float    @default(0)   // peso efetivamente produzido (kg)
  produtividadeEstimada   Float?                  // kg/pessoa/hora estimado
  qtdPessoas              Int      @default(0)    // pessoas no setor naquele dia
  horasNormais            Float    @default(8.8)  // horas normais de trabalho/dia
  horasExtrasProjetadas   Float    @default(0)    // horas extras projetadas
  horasExtrasRealizadas   Float?                  // horas extras realizadas
  observacao              String?
  createdById             String?
  createdBy               User?    @relation("ProducaoDiariaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  pecasPlanejadas         PecaPlanejamento[]

  @@unique([data, setor])
  @@index([data])
  @@index([setor])
}

// Vínculo peça ↔ dia planejado: quais peças serão fabricadas em qual dia/setor.
model PecaPlanejamento {
  id                String          @id @default(cuid())
  producaoDiariaId  String
  producaoDiaria    ProducaoDiaria  @relation(fields: [producaoDiariaId], references: [id], onDelete: Cascade)
  pecaConjuntoId    String
  pecaConjunto      PecaConjunto    @relation(fields: [pecaConjuntoId], references: [id], onDelete: Cascade)
  qtdPlanejada      Int             @default(1)   // quantas unidades daquela peça
  concluida         Boolean         @default(false)
  observacao        String?
  createdAt         DateTime        @default(now())

  @@unique([producaoDiariaId, pecaConjuntoId])
  @@index([pecaConjuntoId])
}

// ─── SHAREPOINT SYNC ────────────────────────────────────────
// Log de cada execucao do sync com SharePoint. Cada tipo (PCP_PRODUCAO, etc.)
// tem o seu fluxo. Permite ver historico, debugar falhas e mostrar "ultima sync".
model SharepointSync {
  id               String   @id @default(cuid())
  tipo             String   // "PCP_PRODUCAO", "COTACOES", etc.
  sucesso          Boolean
  itensProcessados Int      @default(0)
  criados          Int      @default(0)
  atualizados      Int      @default(0)
  mensagem         String?  // texto livre com info do que foi sincronizado
  erro             String?  // mensagem de erro quando sucesso=false
  duracaoMs        Int      @default(0)
  executadoPorId   String?
  executadoPor     User?    @relation(fields: [executadoPorId], references: [id], onDelete: SetNull)
  criadoEm         DateTime @default(now())

  @@index([tipo, criadoEm])
}

// ─── CENTRAL DE ORÇAMENTOS (COMERCIAL) ─────────────────────

enum StatusOrcamento {
  ORCAMENTO       // Proposta em elaboração/enviada
  EM_NEGOCIACAO   // Cliente está negociando
  FECHADA         // Proposta aceita / virou OP
  PERDIDA         // Proposta perdida
}

enum TipoVenda {
  FABRICACAO
  MONTAGEM
  FABRICACAO_E_MONTAGEM
  PINTURA
  MAO_DE_OBRA
  REVENDA
}

enum PorteOrcamento {
  ATE_1_2M        // Até R$ 1,2M
  DE_1_2M_A_10M   // De R$ 1,2M até R$ 10,0M
  DE_10M_A_50M    // De R$ 10M até R$ 50M
  ACIMA_50M       // Acima de R$ 50M
}

model Orcamento {
  id              String            @id @default(cuid())
  numero          String            @unique   // e.g. "001-26"
  cliente         String
  obra            String?
  responsavel     String?           // nome do contato no cliente
  contato         String?           // e-mail do contato
  orcamentista    String?           // quem elaborou o orçamento
  tipoVenda       TipoVenda?
  valor           Float?            // valor total do orçamento
  porte           PorteOrcamento?
  dataSolicitada  DateTime?         // data em que o cliente pediu
  dataEnvio       DateTime?         // data em que enviamos a proposta
  dataFechamento  DateTime?         // data do aceite / perda
  status          StatusOrcamento   @default(ORCAMENTO)
  vendedor        String?           // Vitor, Patrícia, Matheus, Airton, etc.
  motivoPerda     String?           // motivo quando status = PERDIDA
  observacoes     String?

  opId            String?           // OP gerada (quando status = FECHADA)
  op              OP?               @relation("OrcamentoOP", fields: [opId], references: [id], onDelete: SetNull)

  criadoPorId     String?
  criadoPor       User?             @relation("OrcamentoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  revisoes        OrcamentoRevisao[]
  estudos         PropostaEstudo[]

  @@index([status])
  @@index([vendedor])
  @@index([createdAt])
}

model OrcamentoRevisao {
  id            String    @id @default(cuid())
  orcamentoId   String
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  numero        Int       // revisão 1, 2, 3...
  dataEnvio     DateTime?
  observacao    String?
  createdAt     DateTime  @default(now())

  @@index([orcamentoId])
}

// ─── ESTUDO DE PRECIFICAÇÃO (EPC) ──────────────────────────

enum StatusEstudo {
  RASCUNHO        // Em elaboração
  EM_ANALISE      // Sendo revisado
  APROVADO        // Aprovado internamente
  CONCLUIDO       // Proposta gerada
}

enum CategoriaCusto {
  MATERIA_PRIMA
  PARAFUSO
  TINTA
  ENGENHARIA
  QUALIDADE
  TRANSPORTE
  FABRICACAO
  MONTAGEM
  EQUIPAMENTO
  GRADE_DEGRAU
  DESPESA
  PRE_MONTAGEM
  OUTRO
}

enum TipoMaterial {
  PERFIL_W        // W, HP
  PERFIL_U        // U, UE
  PERFIL_L        // Cantoneiras
  TUBO_REDONDO
  TUBO_QUADRADO
  TUBO_RETANGULAR
  CHAPA
  BARRA_REDONDA
  BARRA_CHATA
  BARRA_QUADRADA
  BARRA_ROSCADA
  TELA
  GRADE_PISO
  DEGRAU
  OUTRO
}

enum CategoriaAcessorio {
  TELHA
  CALHA
  RUFO
  GRADE_PISO
  GALVANIZACAO
  STEEL_DECK
  POLICARBONATO
  ISOLAMENTO
  OUTRO
}

model PropostaEstudo {
  id                String          @id @default(cuid())
  orcamentoId       String
  orcamento         Orcamento       @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  revisao           Int             @default(0)   // R0, R1, R2...
  status            StatusEstudo    @default(RASCUNHO)
  referencia        String?         // ENC-0333, referência do cliente
  sharepointUrl     String?         // link para pasta no SharePoint

  // Totais calculados (denormalizados para performance)
  pesoTotal         Float?          // kg
  areaTotal         Float?          // m² de pintura
  custoMaterial     Float?          // R$ total materiais
  custoFabricacao   Float?          // R$ total fabricação
  custoMontagem     Float?          // R$ total montagem
  custoTerceiros    Float?          // R$ total terceiros
  bdiValor          Float?          // R$ valor do BDI
  valorTotal        Float?          // R$ valor total com BDI

  // Produtividade (mão de obra de fabricação)
  tipoObra          String?         // PIPE_RACK, ESTRUTURAL_PESADA, ESTRUTURAL_MEDIA, etc.
  hhPorTon          Float?          // Hh/ton conforme tipo de obra
  custoMoKg         Float?          // R$/kg mão de obra calculado

  // Percentuais de perda e configurações
  percPerda         Float           @default(12)  // % de perda sobre matéria prima
  percParafusos     Float           @default(0.60) // R$/kg de parafusos
  percPesoParafusos Float?          // % sobre peso total para estimar peso de parafusos (quando nao tem lista)

  // Esquema de pintura selecionado (TIPO_1..TIPO_5, SEM_PINTURA, CUSTOMIZADO)
  esquemaPintura    String?         // identificador do esquema selecionado
  esquemaPinturaDesc String?        // descricao customizada (quando esquema = CUSTOMIZADO)
  esquemaPinturaEspessura Float?    // espessura total em µm (editavel)

  // Pintura — calculo por area
  pinturaPercPerda    Float         @default(25)     // % perda de material de pintura
  pinturaMetodo       String        @default("M2")   // "M2" ou "LITRO"
  pinturaCustoM2      Float?                         // R$/m² quando metodo = M2
  pinturaRendimento   Float?                         // m²/L rendimento teorico (metodo = LITRO)
  pinturaCustoLitro   Float?                         // R$/L custo da tinta (metodo = LITRO)

  // Custos por kg (composição de preço)
  custoPinturaKg    Float           @default(0)   // R$/kg custo de pintura
  custoAuxiliarKg   Float           @default(0)   // R$/kg material auxiliar de fabrica
  custoFinanceiroKg Float           @default(0)   // R$/kg despesas financeiras
  custoDemaisKg     Float           @default(0)   // R$/kg demais custos

  // Créditos tributários sobre compras (reduz custo efetivo de materiais)
  // Estimativa inicial = pior cenário (alíquotas padrão). Compras atualiza com valores reais.
  percCreditoICMS   Float           @default(12)   // % crédito ICMS sobre materiais
  percCreditoPIS    Float           @default(1.65)  // % crédito PIS sobre materiais
  percCreditoCOFINS Float           @default(7.60)  // % crédito COFINS sobre materiais
  creditoConfirmado Boolean         @default(false) // false=estimativa, true=confirmado por Compras

  // BDI
  cfopPrincipal     String?         // 5101, 6101, etc.
  bdiAdmin          Float           @default(0)   // %
  bdiSeguro         Float           @default(0)   // %
  bdiRisco          Float           @default(0)   // %
  bdiFactoring      Float           @default(1.6) // % despesas financeiras
  bdiLucro          Float           @default(6.0) // % margem de lucro
  bdiComissao       Float           @default(0)   // %
  // Impostos
  aliqPIS           Float           @default(1.65)
  aliqCOFINS        Float           @default(7.60)
  aliqCSLL          Float           @default(1.08)
  aliqIRPJ          Float           @default(3.00)
  aliqICMS          Float           @default(18.00)
  aliqISS           Float           @default(0)

  observacoes       String?

  criadoPorId       String?
  criadoPor         User?           @relation("EstudoCriadoPor", fields: [criadoPorId], references: [id], onDelete: SetNull)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  itensPerso        PesoProjetoItem[]
  itensAcessorio    AcessorioItem[]
  itensParafuso     ParafusoItem[]
  itensPintura      PinturaItem[]
  itensCusto        CustoItem[]
  itensFaturamento  FaturamentoEvento[]
  itensCronograma   CronogramaItem[]
  documentos        PropostaDocumento[]

  @@index([orcamentoId])
  @@index([status])
}

// Cronograma de Fabricação — timeline por grupo de material para enviar ao cliente
model CronogramaItem {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  grupo           String          // "Colunas", "Vigas Principais", "Guarda-corpo", etc.
  descricao       String?         // detalhes do que inclui
  pesoKg          Float           @default(0)   // peso total do grupo em kg
  diasFabricacao  Int             @default(0)   // dias uteis de fabricação
  diasMontagem    Int?                          // dias uteis de montagem (opcional)
  semanaInicio    Int             @default(1)   // semana de inicio (base 1)
  cor             String?                       // cor hex para a barra (#3B82F6)
  observacao      String?
  ordem           Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([estudoId])
}

// Cenário de Faturamento — eventos de pagamento com classificação fiscal
model FaturamentoEvento {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  descricao       String          // Ex: "Sinal", "Material", "Montagem", "Projeto"
  tipoNota        String          // "NFE" (produto) ou "NFSE" (servico)
  cfop            String?         // CFOP para NF-e (5101, 6101, etc.)
  codigoServico   String?         // Codigo LC 116 para NFS-e (7.02, 14.06, etc.)
  percentual      Float           // % do valor total da proposta
  ordem           Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([estudoId])
}

model PesoProjetoItem {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  setor           String?         // TRASEIRA, FRONTAL, DESAERADOR, etc.
  projeto         String?         // nome do projeto/desenho
  tipoMaterial    TipoMaterial    @default(OUTRO)
  descricao       String          // W200X15, CHAPA#9,50, etc.
  norma           String?         // ASTM A572 Gr. 50, A36, etc.
  comprimento     Float?          // metros ou m²
  pesoUnitario    Float           // kg/m ou kg/m²
  quantidade      Int             @default(1)
  pesoTotal       Float           // kg (calculado)
  areaPintura     Float?          // m²
  ordem           Int             @default(0) // para manter a ordem do levantamento

  // Vinculacao com cadastro Omie
  codigoOmie      String?         // codigo do produto no Omie (ex: 501000003)
  descricaoOmie   String?         // descricao completa no Omie
  custoUnitario   Float?          // CMC (Custo Medio Contabil) em R$/kg

  createdAt       DateTime        @default(now())

  @@index([estudoId])
}

model AcessorioItem {
  id              String              @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo      @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  categoria       CategoriaAcessorio  @default(OUTRO)
  descricao       String              // "Telha TP40 0,50mm Galvalume"
  especificacao   String?             // detalhes tecnicos extras
  unidade         String              @default("un") // m2, m, un, kg, vb
  quantidade      Float               @default(0)
  custoUnitario   Float?              // R$ por unidade (preenchido na aba Custos)
  margemAdm       Float               @default(15)  // % margem administrativa sobre revenda
  faturamentoDireto Boolean           @default(false) // true = fornecedor fatura direto pro cliente (sem crédito tributário)
  observacao      String?
  ordem           Int                 @default(0)

  createdAt       DateTime            @default(now())

  @@index([estudoId])
  @@index([categoria])
}

// ── Parafusos ──────────────────────────────────────────────

enum TipoParafuso {
  PARAFUSO
  PORCA
  ARRUELA
  CHUMBADOR
  BARRA_ROSCADA
  CONECTOR
  INSERTO
  OUTRO
}

model ParafusoItem {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  tipo            TipoParafuso    @default(PARAFUSO)
  descricao       String          // "Parafuso sextavado M16x50 A325"
  especificacao   String?         // "ASTM A325, galvanizado"
  diametro        String?         // "M16", "5/8"", "3/4""
  comprimento     String?         // "50mm", "2""
  unidade         String          @default("un")
  quantidade      Float           @default(0)
  estimativa      Boolean         @default(false) // true = qtd estimada pela IA/regra
  observacao      String?
  ordem           Int             @default(0)

  createdAt       DateTime        @default(now())

  @@index([estudoId])
  @@index([tipo])
}

// ── Pintura ────────────────────────────────────────────────

enum TipoPintura {
  PRIMER
  ESMALTE
  EPOXI
  POLIURETANO
  GALVANIZACAO_FRIO
  INTUMESCENTE
  ZARCAO
  ALQUIDICA
  OUTRO
}

model PinturaItem {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  tipoPintura     TipoPintura     @default(OUTRO)
  descricao       String          // "Primer epoxi cinza + esmalte branco"
  especificacao   String?         // "Conforme N-1550 rev E"
  areaM2          Float           @default(0)    // area de pintura em m²
  demaos          Int             @default(1)    // 1, 2 ou 3 demaos
  espessuraMicra  Float?          // espessura seca por demao (µm)
  unidade         String          @default("m2") // m2, vb
  quantidade      Float           @default(0)    // area total (area x demaos) ou verba
  cor             String?         // "RAL 7035", "Cinza N6.5"
  norma           String?         // "Petrobras N-1550", "SSPC-SP6"
  observacao      String?
  ordem           Int             @default(0)

  createdAt       DateTime        @default(now())

  @@index([estudoId])
  @@index([tipoPintura])
}

model CustoItem {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  categoria       CategoriaCusto
  descricao       String
  unidade         String?         // kg, m², un, vb, L
  quantidade      Float           @default(0)
  precoUnitario   Float           @default(0)
  subtotal        Float           @default(0)  // quantidade × precoUnitario
  percImpostos    Float?          // % de imposto sobre este item
  percInsumos     Float?          // % de insumos
  observacao      String?
  ordem           Int             @default(0)

  createdAt       DateTime        @default(now())

  @@index([estudoId])
  @@index([categoria])
}

model PropostaDocumento {
  id              String          @id @default(cuid())
  estudoId        String
  estudo          PropostaEstudo  @relation(fields: [estudoId], references: [id], onDelete: Cascade)

  nome            String          // nome do arquivo
  tipo            String          // pdf, xlsx, dxf, eml, docx, etc.
  tamanho         Int?            // bytes
  blobUrl         String          // URL no Vercel Blob
  categoria       String?         // email, projeto, documento, cotacao
  observacao      String?

  criadoEm        DateTime        @default(now())

  @@index([estudoId])
}

// Banco de Dados de Materiais — tabela de referência de perfis metálicos
model BDMPerfil {
  id              String          @id @default(cuid())
  tipo            TipoMaterial
  codigo          String          @unique // W200X15, U150X50X3, CHAPA#9,50
  descricao       String?         // descrição longa
  pesoUnitario    Float           // kg/m ou kg/m²
  secao           Float?          // mm (perímetro para cálculo de pintura)
  precoRef        Float?          // preço de referência R$/kg (atualizado via CMC)
  fontePreco      String?         // "CMC", "Cotação Fornecedor", "Manual"
  dataPreco       DateTime?       // quando o preço foi atualizado
  ativo           Boolean         @default(true)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tipo])
  @@index([codigo])
}

// ─── INTEGRAÇÃO MES (SYNECO/SKA) ───────────────────────────
// Apontamentos de produção importados do sistema MES local (SKA Syneco).
// Sincronizados pelo agente local (scripts/mes-sync-agent.js) que roda
// via Task Scheduler na máquina do servidor interno.

model MesApontamento {
  id           String   @id @default(cuid())

  // Chave única do SKA — ProductionID é inteiro único por apontamento no dataset 242
  productionId Int      @unique  // ProductionID do SKA (chave de upsert)

  // Dados do apontamento (dataset 242 — Rastreabilidade de OP e Item [TORG] - Produção)
  dataInicio   DateTime // Data de Início (DD/MM/YYYY HH:mm:ss no SKA)
  dataFim      DateTime? // Data de Fim
  obra         String   // campo "Obra" do SKA = número da OP no portal (T70, T78...)
  opSka        String?  // campo "OP" do SKA = código interno da peça (1SOC-001, T78C3...)
  setor        String?  // Setor (Corte, Montagem, Solda, Acabamento, etc.)
  maquina      String?  // Máquina (LASER CHAPA, MONTAGEM 2, SOLDA 4...)
  codigoMaquina String? // Código da máquina (09, 30B, 40D...)
  operacao     String?  // Operação (10, 30, 40, 50...)
  descricaoItem String? // Desc. Item
  operador     String?  // nome do operador
  status       String?  // Produzindo | Finalizado | Finalizado Total | Finalizado Parcial

  // Quantidades produzidas
  produzidoUn  Float    @default(0)  // campo "Produzido" (unidades)
  rejeitado    Float    @default(0)  // campo "Rejeitado"
  retrabalhado Float    @default(0)  // campo "Retrabalhado"
  produzidoKg  Float    @default(0)  // campo "Peso" (kg)

  // Vínculo com OP do portal (resolvido durante sync via campo Obra)
  opId         String?
  op           OP?      @relation("MesApontamentosOP", fields: [opId], references: [id], onDelete: SetNull)

  // Controle de sync
  syncRunId    String?  // ID do MesSyncLog que criou/atualizou este registro
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([opId])
  @@index([obra])
  @@index([dataInicio])
  @@index([setor])
  @@index([status])
}

// Log de cada execução do sync com o MES SKA.
model MesSyncLog {
  id               String   @id @default(cuid())
  sucesso          Boolean
  dataInicio       DateTime // período sincronizado (início)
  dataFim          DateTime // período sincronizado (fim)
  totalLinhas      Int      @default(0) // linhas retornadas pelo SKA
  criados          Int      @default(0)
  atualizados      Int      @default(0)
  ignorados        Int      @default(0)
  erro             String?
  duracaoMs        Int      @default(0)
  criadoEm         DateTime @default(now())

  @@index([criadoEm])
  @@index([sucesso])
}

// ─── RECEBIMENTOS (NF de entrada) ─────────────────────────────────
// Registra cada recebimento parcial ou total de materiais.
// Pode ser criado automaticamente pelo sync Omie ou manualmente pelo usuario.
model Recebimento {
  id              String   @id @default(cuid())

  // Vinculo ao pedido de compra
  pedidoOmieId    String?
  pedidoOmie      PedidoOmie? @relation(fields: [pedidoOmieId], references: [id])

  // Vinculo ao item especifico da RM (granularidade por item)
  rmItemId        String?
  rmItem          RMItem?  @relation(fields: [rmItemId], references: [id])

  // Quantidades
  qtdRecebida     Float    // quantidade efetivamente recebida neste registro
  unidade         String?  // KG, UN, etc.

  // Data do recebimento
  dataRecebimento DateTime @default(now())

  // Dados da NF
  nfNumero        String?  // numero da NF-e
  nfChave         String?  // chave de acesso 44 digitos
  nfSerie         String?

  // Origem do registro
  origem          RecebimentoOrigem @default(MANUAL)
  observacao      String?

  // Quem registrou (null = sync automatico)
  createdById     String?
  createdBy       User?    @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  @@index([pedidoOmieId])
  @@index([rmItemId])
  @@index([dataRecebimento])
}

enum RecebimentoOrigem {
  MANUAL    // usuario registrou manualmente
  OMIE_SYNC // detectado automaticamente pelo sync
}

// ─── CONFIGURAÇÃO DO ASSISTENTE IA (Torguinho) ──────────────────────────────

model ConfigAssistente {
  id                 String   @id @default(cuid())
  ativo              Boolean  @default(true)
  // Módulos que podem usar o chat. Vazio = todos os módulos habilitados.
  modulosHabilitados String[] @default([])
  // claude-haiku-4-5 (barato) ou claude-sonnet-4-5 (mais capaz)
  modelo             String   @default("claude-haiku-4-5")
  // Instrução extra adicionada ao final do system prompt
  instrucaoExtra     String?
  updatedAt          DateTime @updatedAt
}
