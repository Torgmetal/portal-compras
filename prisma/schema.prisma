  id           String   @id @default(cuid())
  opNumero     String   @unique
  opId         String?
  status       String   @default("ENVIADO") // ENVIADO | EM_EXPEDICAO | CONCLUIDO
  enviadoPorId String?
  enviadoEm    DateTime @default(now())
  observacao   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([opNumero])
  @@index([status])
}

