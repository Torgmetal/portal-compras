model PecaConjunto {
  id                     String                  @id @default(cuid())
  opId                   String?
  opNumero               String
  item                   Int?
  marca                  String
  descricao              String?
  qte                    Int                     @default(1)
  pesoUnitKg             Float                   @default(0)
  pesoTotalKg            Float                   @default(0)
  status                 String                  @default("PENDENTE")
  fluxoEspecial          Boolean                 @default(false)
  ultimoSetor            String?
  dataConcluida          DateTime?
  dataPrevista           DateTime?
  fonte                  String?
  observacao             String?
  criadoEm               DateTime                @default(now())
  atualizadoEm           DateTime                @updatedAt
  precoTotal             Float                   @default(0)
  precoUnitario          Float                   @default(0)
  // Campos LPC — conjunto/croqui
  tipoPeca               String? // "CONJUNTO" | "CROQUI" | null (legado LE)
  material               String? // "A36", "A572-GR.50"
  perfil                 String? // "W410X46.1", "CH4.80X70"
  comprimentoMm          Float? // comprimento em mm
  areaPinturaM2          Float? // area de pintura m²
  statusPrep             String? // "PENDENTE" | "PREPARADO" (so croquis)
  maquina                String? // maquina de corte atribuida (LASER_CHAPA, LASER_PERFIL, LASER_TUBO, LASER_CANTONEIRA)
  statusEstoque          String? // "DISPONIVEL" | "PARCIAL" | "INDISPONIVEL" | null (nao conferido)
  prioridade             Int? // prioridade manual na Programação (vazia = sem prioridade); preservada na reimportação LPC
  ordemCampo             Int? // ordem de envio a campo (1 = primeiro); vazio = sem prioridade
  // Serviço terceirizado — peça fabricada por terceiros: NÃO passa pelo corte; fica em
  // espera (status TERCEIRIZADO) até o Compras receber, então é liberada pro destino.
  terceirizado           Boolean                 @default(false)
  destinoTerceirizado    String? // "MONTAGEM" | "PINTURA" | "EXPEDICAO"
  terceirizadoRecebidoEm DateTime?
  // Fila / kanban de corte (programação pós-liberação). As datas META não
  // mudam depois de programadas; o real vem dos botões Iniciar/Concluir.
  corteOrdem             Int? // posição na fila (menor = corta primeiro)
  corteDataMetaInicio    DateTime?               @db.Date
  corteDataMetaFim       DateTime?               @db.Date
  corteIniciadoEm        DateTime? // real início do corte
  corteConcluidoEm       DateTime? // real fim do corte
  // Campos de produção (populados pelo Syneco)
  qteProduzida           Int                     @default(0)
  pesoProduzido          Float                   @default(0)
  dataProducao           DateTime? // data fim da produção (Syneco)
  op                     OP?                     @relation(fields: [opId], references: [id])
  planejamentos          PecaPlanejamento[]
  planejamentoCargaItens PlanejamentoCargaItem[]
  romaneioItens          RomaneioItem[]
  // Relacoes conjunto<->croqui (many-to-many via junction)
  conjuntoCroquis        ConjuntoCroqui[]        @relation("ConjuntoCroquis_conjunto")
  croquiConjuntos        ConjuntoCroqui[]        @relation("ConjuntoCroquis_croqui")
  entregas               ConjuntoEntrega[]

  @@unique([opNumero, marca])
  @@index([opId])
  @@index([status])
  @@index([marca])
  @@index([tipoPeca])
}

// Divisão da entrega de um conjunto por endereço/local (mesma OP pode ter
// vários destinos; cada linha = quantas unidades vão para aquele local).
model ConjuntoEntrega {
  id             String       @id @default(cuid())
  pecaConjuntoId String
  destino        String // local/endereço de entrega
  quantidade     Int          @default(0)
  createdAt      DateTime     @default(now())
  pecaConjunto   PecaConjunto @relation(fields: [pecaConjuntoId], references: [id], onDelete: Cascade)

  @@index([pecaConjuntoId])
}

// Relacao many-to-many: qual croqui pertence a qual conjunto
model ConjuntoCroqui {
  id            String       @id @default(cuid())
  conjuntoId    String
  croquiId      String
  qtdNoConjunto Int          @default(1)
  conjunto      PecaConjunto @relation("ConjuntoCroquis_conjunto", fields: [conjuntoId], references: [id], onDelete: Cascade)
  croqui        PecaConjunto @relation("ConjuntoCroquis_croqui", fields: [croquiId], references: [id], onDelete: Cascade)

  @@unique([conjuntoId, croquiId])
  @@index([conjuntoId])
  @@index([croquiId])
}

