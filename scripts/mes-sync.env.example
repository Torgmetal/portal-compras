# Configuração do agente MES Sync (SKA Syneco → Portal Torg)
# Copiar para .env na mesma pasta e preencher os valores reais

# API do SKA Syneco (servidor local)
SKA_API_URL=http://192.168.0.190:1000
SKA_USER=seu_usuario_ska
SKA_PASS=sua_senha_ska
SKA_DATASET_ID=126

# Portal Torg (produção)
PORTAL_API_URL=https://workspace.torg.com.br
PORTAL_API_KEY=coloque_aqui_a_chave_gerada_no_portal

# Quantos dias para trás buscar a cada sync (default: 1 = ontem + hoje)
SYNC_DIAS_ATRAS=1

# Arquivo de log (opcional — default: mes-sync.log na mesma pasta)
# LOG_FILE=C:\MesSync\mes-sync.log
